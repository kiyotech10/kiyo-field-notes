---
interface Props {
	title: string;
	category: string;
	size?: 'default' | 'large';
}
const { title, category, size = 'default' } = Astro.props;

const catMeta: Record<string, { label: string; color: string; bg: string }> = {
	diary:    { label: 'Diary',     color: '#c45c4a', bg: '#fdf6f5' },
	english:  { label: 'English',   color: '#3476a8', bg: '#f3f8fc' },
	study:    { label: 'Study',     color: '#7060b0', bg: '#f6f4fb' },
	reading:  { label: 'Reading',   color: '#b07830', bg: '#fdf8ef' },
	lifehack: { label: 'Lifehack',  color: '#4a9068', bg: '#f2faf6' },
	nursing:  { label: 'Nursing',   color: '#1e9b8a', bg: '#f1fbf9' },
};

const meta = catMeta[category] ?? { label: category, color: '#6b7280', bg: '#f9fafb' };
---

<div
	class={`thumb size-${size}`}
	style={`--cat-color:${meta.color};--cat-bg:${meta.bg};`}
	aria-hidden="true"
>
	<div class="thumb-inner">
		<span class="cat-label">{meta.label}</span>
		<span class="thumb-title">{title}</span>
		<span class="thumb-rule"></span>
	</div>
</div>

<style>
	.thumb {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		width: 100%;
		background: var(--cat-bg);
		border: 1px solid var(--border);
	}
	.size-large {
		aspect-ratio: 4 / 3;
	}

	/* thin accent bar at top */
	.thumb::before {
		content: '';
		position: absolute;
		top: 0; left: 0; right: 0;
		height: 2px;
		background: var(--cat-color);
	}

	/* small size: clean color block, no text */
	.thumb-inner {
		display: none;
	}

	/* large size: show title + rule */
	.size-large .thumb-inner {
		display: flex;
		position: absolute;
		inset: 0;
		padding: 1.3em 1.4em;
		flex-direction: column;
		justify-content: flex-end;
		gap: 0.55em;
	}

	.cat-label {
		font-family: var(--font-heading);
		font-size: 0.6em;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--cat-color);
		font-weight: 500;
	}

	.thumb-title {
		display: -webkit-box;
		font-family: var(--font-heading);
		font-size: 1.05em;
		font-weight: 500;
		color: var(--text);
		line-height: 1.5;
		letter-spacing: -0.01em;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.thumb-rule {
		display: block;
		width: 24px;
		height: 1px;
		background: var(--cat-color);
		opacity: 0.5;
	}
</style>
