---
interface Props {
	title: string;
	category: string;
	size?: 'default' | 'large';
	heroImage?: string;
}
const { title, category, size = 'default', heroImage } = Astro.props;

const catMeta: Record<string, { label: string; color: string; bg: string }> = {
	diary:    { label: 'Diary',     color: '#c45c4a', bg: '#fdf6f5' }, // Muted Coral
	english:  { label: 'English',   color: '#1a73e8', bg: '#e8f0fe' }, // Google Blue
	study:    { label: 'Study',     color: '#a142f4', bg: '#f3e8fd' }, // Google Purple
	reading:  { label: 'Reading',   color: '#e37400', bg: '#fef3e6' }, // Google Orange
	lifehack: { label: 'Lifehack',  color: '#137333', bg: '#e6f4ea' }, // Google Green
	nursing:  { label: 'Nursing',   color: '#007b83', bg: '#e4f7f8' }, // Google Teal
};

const meta = catMeta[category] ?? { label: category, color: '#5f6368', bg: '#f1f3f4' };
---

<div
	class={`thumb size-${size} ${heroImage ? 'has-img' : ''}`}
	style={`--cat-color:${meta.color};--cat-bg:${meta.bg};`}
	aria-hidden="true"
>
	{heroImage ? (
		<img src={heroImage} alt="" class="thumb-img" loading="lazy" decoding="async" />
	) : (
		<div class="fallback-gradient"></div>
	)}
	<div class="thumb-inner">
		<span class="cat-label">{meta.label}</span>
		<span class="thumb-title">{title}</span>
		<span class="thumb-rule"></span>
	</div>
</div>

<style>
	.thumb {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		width: 100%;
		background: var(--cat-bg);
		border: 1px solid rgba(0, 0, 0, 0.04); /* Subtly soft hairline boundary */
		border-radius: 12px; /* Material 3 Style Rounded Corners */
		transition: var(--transition-google);
	}
	.size-large {
		aspect-ratio: 4 / 3;
		border-radius: 20px; /* Slightly larger border radius for featured cards */
	}

	/* small size: clean color block, no text */
	.thumb-inner {
		display: none;
	}

	.thumb-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition-google);
	}

	.fallback-gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, var(--cat-bg) 0%, rgba(255, 255, 255, 0.5) 100%);
		transition: var(--transition-google);
	}

	.size-large.has-img::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, var(--cat-bg) 0%, rgba(255, 255, 255, 0.6) 50%, rgba(255, 255, 255, 0) 100%);
		pointer-events: none;
		z-index: 1;
	}

	/* large size: show title + rule + dot indicator */
	.size-large::before {
		content: '';
		position: absolute;
		top: 16px;
		left: 18px;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--cat-color);
		z-index: 2;
	}

	.size-large .thumb-inner {
		display: flex;
		position: absolute;
		inset: 0;
		padding: 1.4em 1.5em;
		flex-direction: column;
		justify-content: flex-end;
		gap: 0.6em;
		z-index: 2;
	}

	.cat-label {
		font-family: var(--font-heading);
		font-size: 0.62em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--cat-color);
		font-weight: 700;
		padding-left: 14px; /* Align with the indicator dot */
	}

	.thumb-title {
		display: -webkit-box;
		font-family: var(--font-heading);
		font-size: 1.1em;
		font-weight: 700;
		color: var(--text);
		line-height: 1.45;
		letter-spacing: -0.01em;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.thumb-rule {
		display: block;
		width: 20px;
		height: 2px;
		background: var(--cat-color);
		opacity: 0.4;
		border-radius: 999px;
	}
</style>
