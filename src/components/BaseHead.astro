---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, ogImage, ogType = 'website' } = Astro.props;
const ogImageURL = ogImage
	? new URL(ogImage, Astro.site).toString()
	: new URL('/og-default.svg', Astro.site).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Tailwind CSS and custom fonts / icons -->
<script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<script is:inline id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        "colors": {
                "outline": "#9a9a9a",
                "on-primary-fixed": "#1a1a1a",
                "text-primary": "#1a1a1a",
                "inverse-surface": "#1a1a1a",
                "on-tertiary": "#ffffff",
                "border-subtle": "rgba(0, 0, 0, 0.08)",
                "outline-variant": "#e0e0e0",
                "on-tertiary-fixed-variant": "#4a4a4a",
                "secondary-container": "#f2f2f2",
                "surface": "#ffffff",
                "text-secondary": "#6b6b6b",
                "surface-bright": "#ffffff",
                "on-error": "#ffffff",
                "on-background": "#1a1a1a",
                "error": "#b3261e",
                "tertiary-fixed": "#f2f2f2",
                "tertiary-container": "#4a4a4a",
                "surface-dim": "#ededed",
                "surface-container-highest": "#e4e4e4",
                "on-primary": "#ffffff",
                "on-secondary-fixed-variant": "#4a4a4a",
                "on-secondary-container": "#4a4a4a",
                "inverse-on-surface": "#ffffff",
                "surface-container": "#f6f6f6",
                "on-secondary-fixed": "#1a1a1a",
                "error-container": "#f9dedc",
                "on-surface-variant": "#4a4a4a",
                "on-secondary": "#ffffff",
                "on-tertiary-container": "#ffffff",
                "primary-container": "#f2f2f2",
                "surface-tint": "#1a1a1a",
                "on-surface": "#1a1a1a",
                "primary-fixed": "#f2f2f2",
                "tertiary-fixed-dim": "#d0d0d0",
                "inverse-primary": "#cfcfcf",
                "secondary-fixed": "#f2f2f2",
                "on-tertiary-fixed": "#1a1a1a",
                "on-primary-fixed-variant": "#4a4a4a",
                "surface-variant": "#f2f2f2",
                "primary-fixed-dim": "#d0d0d0",
                "surface-glass": "#ffffff",
                "surface-container-low": "#fafafa",
                "secondary": "#4a4a4a",
                "on-primary-container": "#1a1a1a",
                "background": "#ffffff",
                "on-error-container": "#410e0b",
                "primary": "#1a1a1a",
                "surface-container-lowest": "#ffffff",
                "tertiary": "#4a4a4a",
                "secondary-fixed-dim": "#d0d0d0",
                "surface-container-high": "#efefef"
        },
        "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
        },
        "spacing": {
                "container-max": "1100px",
                "stack-lg": "48px",
                "margin-mobile": "20px",
                "stack-sm": "8px",
                "gutter": "24px",
                "stack-md": "16px"
        },
        "fontFamily": {
                "headline-lg": ["Plus Jakarta Sans"],
                "headline-lg-mobile": ["Plus Jakarta Sans"],
                "label-sm": ["Inter"],
                "body-lg": ["Inter"],
                "headline-md": ["Plus Jakarta Sans"],
                "body-md": ["Inter"]
        },
        "fontSize": {
                "headline-lg": ["32px", {"lineHeight": "1.3", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                "headline-lg-mobile": ["24px", {"lineHeight": "1.3", "fontWeight": "700"}],
                "label-sm": ["12px", {"lineHeight": "1", "letterSpacing": "0.05em", "fontWeight": "600"}],
                "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                "headline-md": ["20px", {"lineHeight": "1.4", "fontWeight": "600"}],
                "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}]
        }
      },
    },
  }
</script>

<link rel="canonical" href={canonicalURL} />

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-MQBHP6Z0PL"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-MQBHP6Z0PL');
</script>

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="ja_JP" />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageURL} />
