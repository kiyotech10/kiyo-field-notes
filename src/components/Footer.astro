---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="w-full py-12 mt-16 bg-[#ffffff] border-t border-black/[0.05]">
	<div class="max-w-[1100px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
		<div>
			<h2 class="font-headline-md text-lg text-primary mb-3 font-bold">{SITE_TITLE}</h2>
			<p class="text-xs text-text-secondary opacity-85 mb-4">© {today.getFullYear()} {SITE_TITLE}. Precision in Care, Clarity in Learning.</p>
		</div>
		<div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
			<div class="flex flex-col gap-1.5">
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/diary">Diary</a>
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/english">English</a>
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/study">Study</a>
			</div>
			<div class="flex flex-col gap-1.5">
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/reading">Reading</a>
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/nursing">Nursing</a>
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/lifehack">Lifehack</a>
			</div>
			<div class="flex flex-col gap-1.5">
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/about">About</a>
				<a class="text-xs text-text-secondary hover:text-primary transition-all hover:underline" href="/contact">Contact</a>
			</div>
		</div>
	</div>
</footer>

<button id="back-to-top" class="fixed bottom-8 right-8 w-12 h-12 rounded-full bg-primary text-white shadow-xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 pointer-events-none opacity-0 z-50">
	<span class="material-symbols-outlined text-lg">arrow_upward</span>
</button>

<script is:inline>
	// Back to top behavior
	const btn = document.getElementById('back-to-top');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 300) {
			btn?.classList.remove('opacity-0', 'pointer-events-none');
			btn?.classList.add('opacity-100');
			btn?.setAttribute('style', 'pointer-events: auto;');
		} else {
			btn?.classList.add('opacity-0', 'pointer-events-none');
			btn?.classList.remove('opacity-100');
			btn?.removeAttribute('style');
		}
	});
	btn?.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});

	// Scroll fade-in transition
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.08 }
	);
	document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
