---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} Kiyo. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		margin-top: 4em;
	}
	.footer-inner {
		padding: 2rem max(1.5rem, 4vw);
	}
	p {
		font-size: 0.8em;
		color: var(--text-muted);
		margin: 0;
		letter-spacing: 0.03em;
	}
</style>
