---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-inner">
		<div class="site-title">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<nav>
			<HeaderLink href="/diary">Diary</HeaderLink>
			<HeaderLink href="/english">English</HeaderLink>
			<HeaderLink href="/study">Study</HeaderLink>
			<HeaderLink href="/reading">Reading</HeaderLink>
			<HeaderLink href="/nursing">Nursing</HeaderLink>
			<HeaderLink href="/lifehack">Lifehack</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
		background: var(--bg);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		max-width: calc(var(--max-width) + 4rem);
		margin: 0 auto;
		padding: 1.2rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.site-title a {
		font-family: var(--font-heading);
		font-size: 1.25em;
		font-weight: 500;
		color: var(--text);
		text-decoration: none;
		letter-spacing: 0.02em;
	}
	.site-title a:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0 1.6rem;
	}
	nav :global(a) {
		font-size: 0.78em;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		padding: 0.15em 0;
		border-bottom: 1px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	nav :global(a:hover),
	nav :global(a.active) {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		.header-inner {
			padding: 0.9rem 1rem;
		}
		nav {
			gap: 0 1.1rem;
		}
	}
</style>
