---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-inner">
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<nav>
			<HeaderLink href="/diary">Diary</HeaderLink>
			<HeaderLink href="/english">English</HeaderLink>
			<HeaderLink href="/study">Study</HeaderLink>
			<HeaderLink href="/reading">Reading</HeaderLink>
			<HeaderLink href="/nursing">Nursing</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
		background: var(--bg);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		width: 100%;
		padding: 0 max(1.5rem, 4vw);
		height: 52px;
		display: flex;
		align-items: center;
		gap: 2.5rem;
	}
	.site-title {
		font-family: var(--font-heading);
		font-size: 0.82em;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--text);
		text-decoration: none;
		text-transform: uppercase;
		white-space: nowrap;
	}
	.site-title:hover {
		color: var(--accent);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0 1.8rem;
		flex-wrap: wrap;
	}
	nav :global(a) {
		font-size: 0.72em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s;
		font-weight: 400;
	}
	nav :global(a:hover),
	nav :global(a.active) {
		color: var(--text);
		text-decoration: none;
	}
	@media (max-width: 720px) {
		.header-inner {
			padding: 0 1rem;
			height: auto;
			flex-direction: column;
			align-items: flex-start;
			gap: 0;
			padding-top: 0.8rem;
			padding-bottom: 0.8rem;
		}
		nav {
			gap: 0 1.2rem;
		}
	}
</style>
