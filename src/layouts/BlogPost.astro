---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	category?: string;
	readingTime?: number;
	tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, category, readingTime, tags } = Astro.props;

const categoryLabels: Record<string, string> = {
	diary: 'Diary',
	english: 'English',
	study: 'Study',
	reading: 'Reading',
	nursing: 'Nursing',
	lifehack: 'Lifehack',
};

const catColors: Record<string, { accent: string; light: string }> = {
	diary:    { accent: '#c45c4a', light: '#d4776a' },
	english:  { accent: '#1a73e8', light: '#4285f4' },
	study:    { accent: '#a142f4', light: '#bd8dfa' },
	reading:  { accent: '#e37400', light: '#f29900' },
	lifehack: { accent: '#137333', light: '#1e8e3e' },
	nursing:  { accent: '#007b83', light: '#0097a7' },
};
const catStyle = category && catColors[category]
	? `--accent:${catColors[category].accent};--accent-light:${catColors[category].light}`
	: '';
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} ogType="article" />
	</head>
	<body style={catStyle}>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image src={heroImage} alt="" inferSize />
					</div>
				)}
				<div class="post-header">
					{category && (
						<a href={`/${category}/`} class="back-link">
							← {categoryLabels[category] ?? category}
						</a>
					)}
					<h1>{title}</h1>
					{pubDate && (
						<div class="meta">
							<FormattedDate date={pubDate} />
							{readingTime && <span class="reading-time">· 約{readingTime}分</span>}
							{updatedDate && (
								<span class="updated">（更新: <FormattedDate date={updatedDate} />）</span>
							)}
						</div>
					)}
					{tags && tags.length > 0 && (
						<div class="tags-row">
							{tags.map((tag) => (
								<a href={`/tags/${tag}/`} class="tag-chip">#{tag}</a>
							))}
						</div>
					)}
					<hr />
				</div>
				<div class="prose">
					<slot />
				</div>
				<p class="contact-nudge">感想・質問は <a href="/contact">Contact</a> からどうぞ。</p>
			</article>
			<Giscus />
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-image {
		margin-bottom: 2.5em;
	}
	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 20px;
		box-shadow: 0 4px 24px rgba(0,0,0,0.04);
	}
	.post-header {
		margin-bottom: 2em;
	}
	.back-link {
		display: inline-block;
		font-size: 0.68em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 1.4em;
		transition: color 0.15s;
	}
	.back-link:hover {
		color: var(--accent);
		text-decoration: none;
	}
	h1 {
		font-size: 1.8em;
		margin: 0 0 0.5em;
		letter-spacing: -0.02em;
		line-height: 1.3;
		font-weight: 600;
	}
	.meta {
		font-size: 0.78em;
		color: var(--text-muted);
		margin-bottom: 0.5em;
		letter-spacing: 0.02em;
	}
	.reading-time { margin-left: 0.6em; }
	.updated {
		margin-left: 1em;
		font-style: italic;
	}
	.tags-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-top: 0.6em;
	}
	.tag-chip {
		font-size: 0.68em;
		color: var(--text-muted);
		text-decoration: none;
		border: 1px solid #dadce0;
		border-radius: 999px; /* Pill */
		padding: 0.25em 0.8em;
		background: #ffffff;
		transition: var(--transition-google);
	}
	.tag-chip:hover {
		color: var(--accent);
		border-color: var(--accent-light);
		background: rgba(26, 115, 232, 0.04);
		text-decoration: none;
	}
	.contact-nudge {
		font-size: 0.8em;
		color: var(--text-muted);
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid var(--border);
	}
</style>
