---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	category?: string;
	readingTime?: number;
}

const { title, description, pubDate, updatedDate, heroImage, category, readingTime } = Astro.props;

const categoryLabels: Record<string, string> = {
	diary: 'Diary',
	english: 'English',
	study: 'Study',
	reading: 'Reading',
	nursing: 'Nursing',
};
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} ogType="article" />
	</head>
	<body>
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<Image src={heroImage} alt="" inferSize />
						</div>
					)
				}
				<div class="post-header">
					{
						category && (
							<a href={`/${category}/`} class="back-link">
								← {categoryLabels[category] ?? category}
							</a>
						)
					}
					<h1>{title}</h1>
					{
						pubDate && (
							<div class="meta">
								<FormattedDate date={pubDate} />
								{readingTime && <span class="reading-time">· 約{readingTime}分</span>}
								{updatedDate && (
									<span class="updated">
										（更新: <FormattedDate date={updatedDate} />）
									</span>
								)}
							</div>
						)
					}
					<hr />
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-image {
		margin-bottom: 2em;
	}
	.hero-image img {
		display: block;
		width: 100%;
	}
	.post-header {
		margin-bottom: 1.5em;
	}
	.back-link {
		display: inline-block;
		font-size: 0.78em;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 1.2em;
	}
	.back-link:hover {
		color: var(--accent);
	}
	h1 {
		font-size: 2em;
		margin: 0 0 0.4em;
	}
	.meta {
		font-size: 0.82em;
		color: var(--text-muted);
		margin-bottom: 0.5em;
	}
	.reading-time {
		margin-left: 0.6em;
	}
	.updated {
		margin-left: 1em;
		font-style: italic;
	}
</style>
