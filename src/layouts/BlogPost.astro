---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	category?: string;
	readingTime?: number;
}

const { title, description, pubDate, updatedDate, heroImage, category, readingTime } = Astro.props;

const categoryLabels: Record<string, string> = {
	diary: 'Diary',
	english: 'English',
	study: 'Study',
	reading: 'Reading',
	nursing: 'Nursing',
	lifehack: 'Lifehack',
};

const catColors: Record<string, { accent: string; light: string }> = {
	diary:    { accent: '#c45c4a', light: '#d4776a' },
	english:  { accent: '#3476a8', light: '#509cc8' },
	study:    { accent: '#7060b0', light: '#8878c8' },
	reading:  { accent: '#b07830', light: '#c89050' },
	nursing:  { accent: '#1e9b8a', light: '#3ab5a3' },
	lifehack: { accent: '#4a9068', light: '#66a882' },
};
const catStyle = category && catColors[category]
	? `--accent:${catColors[category].accent};--accent-light:${catColors[category].light}`
	: '';
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} ogType="article" />
	</head>
	<body style={catStyle}>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image src={heroImage} alt="" inferSize />
					</div>
				)}
				<div class="post-header">
					{category && (
						<a href={`/${category}/`} class="back-link">
							← {categoryLabels[category] ?? category}
						</a>
					)}
					<h1>{title}</h1>
					{pubDate && (
						<div class="meta">
							<FormattedDate date={pubDate} />
							{readingTime && <span class="reading-time">· 約{readingTime}分</span>}
							{updatedDate && (
								<span class="updated">（更新: <FormattedDate date={updatedDate} />）</span>
							)}
						</div>
					)}
					<hr />
				</div>
				<div class="prose">
					<slot />
				</div>
				<p class="contact-nudge">感想・質問は <a href="/contact">Contact</a> からどうぞ。</p>
			</article>
			<Giscus />
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-image {
		margin-bottom: 2.5em;
	}
	.hero-image img {
		display: block;
		width: 100%;
	}
	.post-header {
		margin-bottom: 2em;
	}
	.back-link {
		display: inline-block;
		font-size: 0.68em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		margin-bottom: 1.4em;
		transition: color 0.15s;
	}
	.back-link:hover {
		color: var(--accent);
		text-decoration: none;
	}
	h1 {
		font-size: 1.8em;
		margin: 0 0 0.5em;
		letter-spacing: -0.02em;
		line-height: 1.3;
		font-weight: 600;
	}
	.meta {
		font-size: 0.78em;
		color: var(--text-muted);
		margin-bottom: 0.5em;
		letter-spacing: 0.02em;
	}
	.reading-time { margin-left: 0.6em; }
	.updated {
		margin-left: 1em;
		font-style: italic;
	}
	.contact-nudge {
		font-size: 0.8em;
		color: var(--text-muted);
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid var(--border);
	}
</style>
