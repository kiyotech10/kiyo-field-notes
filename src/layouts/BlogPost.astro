---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	category?: string;
	readingTime?: number;
	tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, category, readingTime, tags } = Astro.props;

const categoryLabels: Record<string, string> = {
	diary: 'Diary',
	english: 'English',
	study: 'Study',
	reading: 'Reading',
	nursing: 'Nursing',
	lifehack: 'Lifehack',
};

const catColors: Record<string, { accent: string; light: string }> = {
	diary:    { accent: '#c45c4a', light: '#d4776a' },
	english:  { accent: '#1a73e8', light: '#4285f4' },
	study:    { accent: '#a142f4', light: '#bd8dfa' },
	reading:  { accent: '#e37400', light: '#f29900' },
	lifehack: { accent: '#137333', light: '#1e8e3e' },
	nursing:  { accent: '#007b83', light: '#0097a7' },
};
const catStyle = category && catColors[category]
	? `--accent:${catColors[category].accent};--accent-light:${catColors[category].light}`
	: '';
---

<html lang="ja">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} ogType="article" />
	</head>
	<body class="bg-surface text-on-background font-body-md min-h-screen">
		<Header />
		<main class="w-full pt-28 md:pt-32 pb-16 px-5 max-w-[720px] mx-auto">
			<article>
				<div class="post-header mb-8">
					{category && (
						<a href={`/${category}/`} class="inline-block text-xs font-semibold text-text-secondary uppercase tracking-widest mb-4 hover:text-text-primary transition-colors">
							{categoryLabels[category] ?? category}
						</a>
					)}
					<h1 class="text-2xl md:text-[34px] font-bold text-text-primary leading-snug mb-4">{title}</h1>

					{pubDate && (
						<div class="flex flex-wrap items-center gap-2.5 text-xs text-text-secondary mb-2">
							<FormattedDate date={pubDate} />
							{readingTime && (
								<>
									<span class="text-border-subtle">/</span>
									<span>約{readingTime}分</span>
								</>
							)}
							{updatedDate && (
								<>
									<span class="text-border-subtle">/</span>
									<span>更新: <FormattedDate date={updatedDate} /></span>
								</>
							)}
						</div>
					)}
				</div>

				{heroImage && (
					<div class="w-full overflow-hidden rounded mb-10">
						<Image src={heroImage} alt="" class="w-full max-h-[460px] object-cover" inferSize />
					</div>
				)}

				<div class="prose max-w-none">
					<slot />
				</div>

				{tags && tags.length > 0 && (
					<div class="flex flex-wrap gap-2 mt-12">
						{tags.map((tag) => (
							<a href={`/tags/${tag}/`} class="text-xs text-text-secondary hover:text-text-primary transition-colors">
								#{tag}
							</a>
						))}
					</div>
				)}

				<p class="mt-10 pt-8 border-t border-border-subtle text-sm text-text-secondary">
					感想・質問は <a href="/contact" class="text-text-primary underline underline-offset-2 hover:opacity-70">Contact</a> からお気軽にどうぞ。
				</p>
				<p class="mt-3 text-xs text-text-secondary">
					この記事は生成AI（Claude）を用いて執筆しています。詳しくは <a href="/about/#ai-writing" class="text-text-primary underline underline-offset-2 hover:opacity-70">執筆方針</a> をご覧ください。
				</p>
			</article>
			<div class="mt-10">
				<Giscus />
			</div>
		</main>
		<Footer />
	</body>
</html>
