---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	category?: string;
	readingTime?: number;
	tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, category, readingTime, tags } = Astro.props;

const categoryLabels: Record<string, string> = {
	diary: 'Diary',
	english: 'English',
	study: 'Study',
	reading: 'Reading',
	nursing: 'Nursing',
	lifehack: 'Lifehack',
};

const catColors: Record<string, { accent: string; light: string }> = {
	diary:    { accent: '#c45c4a', light: '#d4776a' },
	english:  { accent: '#1a73e8', light: '#4285f4' },
	study:    { accent: '#a142f4', light: '#bd8dfa' },
	reading:  { accent: '#e37400', light: '#f29900' },
	lifehack: { accent: '#137333', light: '#1e8e3e' },
	nursing:  { accent: '#007b83', light: '#0097a7' },
};
const catStyle = category && catColors[category]
	? `--accent:${catColors[category].accent};--accent-light:${catColors[category].light}`
	: '';
---

<html lang="ja">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} ogType="article" />
	</head>
	<body class="bg-surface text-on-background font-body-md min-h-screen">
		<Header />
		<main class="pt-32 pb-stack-lg px-margin-mobile md:px-gutter max-w-[840px] mx-auto">
			<article class="glass-card rounded-2xl p-6 md:p-10 border border-black/[0.05] shadow-[0px_10px_50px_rgba(0,0,0,0.03)] fade-in">
				{heroImage && (
					<div class="w-full h-64 md:h-96 rounded-2xl overflow-hidden mb-8 shadow-sm border border-black/[0.03]">
						<Image src={heroImage} alt="" class="w-full h-full object-cover" inferSize />
					</div>
				)}

				<div class="post-header">
					{category && (
						<a href={`/${category}/`} class="inline-flex items-center gap-1.5 text-xs font-bold text-primary bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full uppercase tracking-wider mb-4 hover:opacity-85 transition-opacity">
							<span class="material-symbols-outlined text-[12px]">arrow_back</span>
							{categoryLabels[category] ?? category}
						</a>
					)}
					<h1 class="font-headline-lg text-headline-lg text-text-primary leading-tight mb-4">{title}</h1>
					
					{pubDate && (
						<div class="flex flex-wrap items-center gap-3 text-xs text-text-secondary border-b border-border-subtle pb-6 mb-6">
							<span class="material-symbols-outlined text-sm text-[#276183]">calendar_month</span>
							<FormattedDate date={pubDate} />
							{readingTime && (
								<>
									<span class="w-1.5 h-1.5 rounded-full bg-zinc-300"></span>
									<span class="material-symbols-outlined text-sm text-[#276183]">schedule</span>
									<span>約{readingTime}分</span>
								</>
							)}
							{updatedDate && (
								<>
									<span class="w-1.5 h-1.5 rounded-full bg-zinc-300"></span>
									<span class="italic text-primary-container">(更新: <FormattedDate date={updatedDate} />)</span>
								</>
							)}
						</div>
					)}
					
					{tags && tags.length > 0 && (
						<div class="flex flex-wrap gap-1.5 mb-8">
							{tags.map((tag) => (
								<a href={`/tags/${tag}/`} class="px-3 py-1 bg-white border border-border-subtle rounded-full text-xs text-text-secondary hover:border-primary hover:text-primary transition-all duration-300">
									#{tag}
								</a>
							))}
						</div>
					)}
				</div>

				<div class="prose prose-slate max-w-none prose-headings:font-bold prose-headings:text-primary prose-h2:text-headline-md prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-border-subtle prose-p:text-text-secondary prose-p:leading-relaxed prose-p:mb-6 prose-a:text-primary prose-a:font-bold hover:prose-a:opacity-80 prose-li:text-text-secondary prose-li:mb-2 prose-strong:text-text-primary prose-blockquote:border-l-4 prose-blockquote:border-primary prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-text-secondary">
					<slot />
				</div>

				<p class="mt-12 pt-8 border-t border-border-subtle text-sm text-text-secondary flex items-center gap-2">
					<span class="material-symbols-outlined text-base text-[#276183]">mail</span>
					感想・質問は <a href="/contact" class="text-primary hover:underline font-bold">Contact</a> からお気軽にお寄せください。
				</p>
			</article>
			<div class="mt-8">
				<Giscus />
			</div>
		</main>
		<Footer />
	</body>
</html>
