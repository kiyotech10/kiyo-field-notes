---
// Formspree setup:
// 1. https://formspree.io でアカウント作成 (sphkiyo@gmail.com)
// 2. 新しいフォームを作成 → Form ID (例: xpwzjkxy) を取得
// 3. 下記 FORM_ID を置き換える
const FORM_ID = 'YOUR_FORM_ID';

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Contact — ${SITE_TITLE}`} description="お問い合わせ・感想はこちらから。" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Contact</h1>
			<p class="lead">ご感想・ご質問など、お気軽にどうぞ。</p>
			<hr />

			<form
				class="contact-form"
				action={`https://formspree.io/f/${FORM_ID}`}
				method="POST"
			>
				<!-- honeypot: スパムボット対策 -->
				<input type="text" name="_gotcha" class="sr-only" tabindex="-1" autocomplete="off" />

				<div class="field">
					<label for="name">お名前</label>
					<input type="text" id="name" name="name" placeholder="山田 太郎" required />
				</div>

				<div class="field">
					<label for="email">メールアドレス</label>
					<input type="email" id="email" name="email" placeholder="you@example.com" required />
				</div>

				<div class="field">
					<label for="subject">件名</label>
					<input type="text" id="subject" name="subject" placeholder="記事の感想など" />
				</div>

				<div class="field">
					<label for="message">メッセージ <span class="required">*</span></label>
					<textarea id="message" name="message" rows="7" placeholder="メッセージをご記入ください。" required></textarea>
				</div>

				<button type="submit" class="submit-btn">送信する</button>
			</form>

			<p class="note">送信後、自動返信はありません。返信には数日かかる場合があります。</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 2.2em;
		font-weight: 500;
		margin-bottom: 0.3em;
	}
	.lead {
		color: var(--text-muted);
		font-size: 0.92em;
		margin: 0 0 1.5em;
	}
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.4em;
		margin: 2em 0;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	label {
		font-size: 0.82em;
		letter-spacing: 0.04em;
		color: var(--text-muted);
	}
	.required {
		color: #c0392b;
	}
	input[type='text'],
	input[type='email'],
	textarea {
		width: 100%;
		font-family: var(--font-body);
		font-size: 0.95em;
		padding: 0.7em 0.9em;
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 3px;
		color: var(--text);
		transition: border-color 0.15s;
		line-height: 1.6;
		-webkit-appearance: none;
	}
	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--accent);
	}
	textarea {
		resize: vertical;
		min-height: 140px;
	}
	.submit-btn {
		align-self: flex-start;
		font-family: var(--font-heading);
		font-size: 0.9em;
		letter-spacing: 0.08em;
		padding: 0.75em 2em;
		background: var(--accent);
		color: #fff;
		border: none;
		border-radius: 3px;
		cursor: pointer;
		transition: background 0.15s;
	}
	.submit-btn:hover {
		background: var(--accent-light);
	}
	.note {
		font-size: 0.78em;
		color: var(--text-muted);
		margin-top: 0.5em;
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0,0,0,0);
		white-space: nowrap;
		border: 0;
	}
</style>
