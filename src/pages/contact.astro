---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Contact — ${SITE_TITLE}`} description="お問い合わせ・感想はこちらから。" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Contact</h1>
			<p class="lead">ご感想・ご質問はこちらから。</p>
			<hr />

			<p class="note">お問い合わせフォームは現在準備中です。設置までしばらくお待ちください。</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 2.2em;
		font-weight: 500;
		margin-bottom: 0.3em;
	}
	.lead {
		color: var(--text-muted);
		font-size: 0.92em;
		margin: 0 0 1.5em;
	}
	.note {
		font-size: 0.78em;
		color: var(--text-muted);
		margin-top: 0.5em;
	}
</style>
