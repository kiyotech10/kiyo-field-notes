---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('english')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = 'English';
const description = '英語学習の記録。語彙・文法・試験対策など。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
	</head>
	<body class="bg-surface text-on-background font-body-md min-h-screen">
		<Header />
		<main class="w-full pt-32 pb-stack-lg px-margin-mobile md:px-gutter max-w-container-max mx-auto">
			<div class="mb-12 relative fade-in">
				<a href="/" class="inline-flex items-center gap-1.5 text-text-secondary hover:text-primary transition-colors text-xs font-semibold uppercase tracking-wider mb-4">
					<span class="material-symbols-outlined text-[16px]">arrow_back</span>
					Home
				</a>
				<h1 class="font-headline-lg text-headline-lg text-primary mb-3 flex items-center gap-2">
					<span class="material-symbols-outlined text-3xl">language</span>
					{title}
				</h1>
				<p class="font-body-lg text-body-lg text-text-secondary leading-relaxed max-w-2xl">
					{description}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{posts.map((post) => (
					<a href={`/english/${post.id}/`} class="block group">
						<article class="glass-card rounded-xl p-6 md:p-8 antigravity-float flex flex-col justify-between h-full border border-black/[0.05]">
							<div>
								<div class="flex justify-between items-center mb-4 text-xs text-text-secondary">
									<span class="px-2.5 py-0.5 rounded-full bg-secondary-container text-on-secondary-container font-semibold uppercase tracking-wider">
										{title}
									</span>
									<time class="font-label-sm">
										<FormattedDate date={post.data.pubDate} />
									</time>
								</div>
								<h2 class="font-headline-md text-headline-md text-text-primary mb-3 group-hover:text-primary transition-colors line-clamp-2">
									{post.data.title}
								</h2>
								<p class="text-text-secondary text-body-md leading-relaxed line-clamp-3 mb-4">
									{post.data.description}
								</p>
							</div>
							{post.data.tags && post.data.tags.length > 0 && (
								<div class="flex flex-wrap gap-1.5 mt-auto pt-4 border-t border-border-subtle">
									{post.data.tags.map((tag) => (
										<span class="text-primary font-label-sm text-[11px]">#{tag}</span>
									))}
								</div>
							)}
						</article>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
