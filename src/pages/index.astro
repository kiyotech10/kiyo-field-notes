---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const categories = [
	{ id: 'diary', label: 'Diary', desc: '日常の記録' },
	{ id: 'english', label: 'English', desc: '英語学習のメモ' },
	{ id: 'study', label: 'Study', desc: '試験勉強の記録' },
	{ id: 'reading', label: 'Reading', desc: '読書メモ' },
	{ id: 'nursing', label: 'Nursing', desc: '看護に関する考察' },
	{ id: 'about', label: 'About', desc: 'プロフィール' },
];

const allPosts = [
	...(await getCollection('diary')).map((p) => ({ ...p, category: 'diary' as const })),
	...(await getCollection('english')).map((p) => ({ ...p, category: 'english' as const })),
	...(await getCollection('study')).map((p) => ({ ...p, category: 'study' as const })),
	...(await getCollection('reading')).map((p) => ({ ...p, category: 'reading' as const })),
	...(await getCollection('nursing')).map((p) => ({ ...p, category: 'nursing' as const })),
]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 10);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="intro">
				<h1>{SITE_TITLE}</h1>
				<p class="tagline">{SITE_DESCRIPTION}</p>
				<p class="ai-note">※ 記事の文章は主にAIが執筆しています。</p>
			</div>

			<nav class="category-grid">
				{
					categories.map((cat) => (
						<a href={`/${cat.id}/`} class="category-card">
							<span class="cat-label">{cat.label}</span>
							<span class="cat-desc">{cat.desc}</span>
						</a>
					))
				}
			</nav>

			{
				allPosts.length > 0 && (
					<>
						<hr />
						<section class="recent">
							<h2 class="section-heading">Recent</h2>
							<ul class="post-list">
								{allPosts.map((post) => (
									<li>
										<a href={`/${post.category}/${post.id}/`}>
											<span class="post-cat">{post.category}</span>
											<span class="post-title">{post.data.title}</span>
											<span class="post-date">
												<FormattedDate date={post.data.pubDate} />
											</span>
										</a>
									</li>
								))}
							</ul>
						</section>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: 3em;
	}
	.intro h1 {
		font-size: 2em;
		font-weight: 500;
		letter-spacing: 0.02em;
		margin: 0 0 0.4em;
	}
	.tagline {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0 0 0.4em;
	}
	.ai-note {
		color: var(--text-muted);
		font-size: 0.78em;
		margin: 0;
	}
	.category-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.8rem;
		margin-bottom: 3em;
	}
	.category-card {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
		padding: 1.1em 1.3em;
		border: 1px solid var(--border);
		text-decoration: none;
		color: var(--text);
		transition:
			border-color 0.15s,
			background 0.15s;
	}
	.category-card:hover {
		border-color: var(--accent);
		background: rgba(26, 58, 82, 0.04);
		color: var(--text);
	}
	.cat-label {
		font-family: var(--font-heading);
		font-size: 1.05em;
		font-weight: 500;
		letter-spacing: 0.03em;
		color: var(--accent);
	}
	.cat-desc {
		font-size: 0.78em;
		color: var(--text-muted);
	}
	.section-heading {
		font-size: 0.8em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		font-weight: 400;
		margin: 0 0 1.2em;
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		border-bottom: 1px solid var(--border);
	}
	.post-list li:first-child {
		border-top: 1px solid var(--border);
	}
	.post-list a {
		display: flex;
		align-items: baseline;
		gap: 1em;
		padding: 0.85em 0;
		text-decoration: none;
		color: var(--text);
	}
	.post-list a:hover .post-title {
		color: var(--accent);
	}
	.post-cat {
		font-size: 0.68em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
		width: 5em;
		flex-shrink: 0;
	}
	.post-title {
		flex: 1;
		font-size: 0.95em;
	}
	.post-date {
		font-size: 0.78em;
		color: var(--text-muted);
		white-space: nowrap;
	}
	@media (max-width: 600px) {
		.category-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.post-list a {
			flex-wrap: wrap;
			gap: 0.3em;
		}
		.post-date {
			width: 100%;
			padding-left: calc(5em + 1em);
		}
	}
</style>
