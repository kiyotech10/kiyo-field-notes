    <!-- Floating Chatbot Modal Window -->
    <div id="global-chat-window" class="fixed bottom-24 right-8 w-[340px] h-[450px] bg-white/95 rounded-2xl shadow-2xl border border-black/[0.05] z-50 flex flex-col backdrop-blur-md hidden transition-all duration-300 transform scale-95 opacity-0">
        <div class="bg-[#276183] text-white px-4 py-3.5 rounded-t-2xl flex justify-between items-center shadow-sm">
            <div class="flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">auto_awesome</span>
                <span class="font-bold text-xs">Gemini Nurse Assistant</span>
            </div>
            <button id="close-global-chat" class="hover:opacity-85"><span class="material-symbols-outlined text-sm">close</span></button>
        </div>
        <div class="flex-1 p-4 overflow-y-auto space-y-3 text-xs flex flex-col" id="chat-messages-container">
            <div class="bg-zinc-100 text-zinc-800 p-3 rounded-2xl max-w-[85%] self-start leading-relaxed">
                こんにちは！Kiyoさんのブログ「NurseNotes」アシスタントです。医療DX配置基準の改定、英語学習のコツ、全世界積立投資、セルフケアなど、ブログ記事の内容や看護知見について何でも質問してくださいね。
            </div>
        </div>
        <div class="p-3 border-t border-black/[0.05] flex gap-2 items-center bg-[#f8fafb] rounded-b-2xl">
            <input type="text" id="chat-input" class="flex-1 bg-white border border-black/[0.08] px-4 py-2 rounded-full text-xs focus:outline-none focus:border-[#276183]" placeholder="例：英語学習の本質について教えて...">
            <button id="send-chat" class="bg-[#276183] text-white w-8 h-8 rounded-full flex items-center justify-center hover:scale-105 active:scale-95 transition-all"><span class="material-symbols-outlined text-sm">send</span></button>
        </div>
    </div>

    <script>
        // Subtle micro-interaction: Header scroll effect
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if (window.scrollY > 20) {
                header.classList.add('shadow-lg');
            } else {
                header.classList.remove('shadow-lg');
            }
        });

        // AI Chip close logic
        const attribChip = document.getElementById('ai-chip-close');
        if (attribChip) {
            attribChip.addEventListener('click', (e) => {
                const parent = e.currentTarget.closest('.inline-flex');
                parent.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                parent.style.opacity = '0';
                parent.style.transform = 'scale(0.9)';
                setTimeout(() => parent.remove(), 300);
            });
        }

        /* -------------------------------------------------------------
         * AI Chatbot Dialogues Logic
         * ------------------------------------------------------------- */
        const chatbotResponses = [
            {
                keywords: ['英語', 'toeic', 'toeic905', 'english', '勉強'],
                response: 'KiyoさんはTOEIC 905点を達成していますが、「英語ができること」は単なる通過点であり、目的ではないと語っています。実際の臨床や情報収集（一次資料の読解）で活かすことこそが本質的価値です。具体的な学習法としては、継続的なインプットとシャドーイングを重視しています。'
            },
            {
                keywords: ['dx', '医療dx', '改定', '配置基準'],
                response: '令和8年度の医療DX改定について、Kiyoさんは「急性期看護配置基準の柔軟化」に注目しています。これは現場のICT導入（スマートベッド、自動点滴監視等）によって、単純な人員配置から、実際のケア密度に応じた柔軟な運用への移行を促すものです。これにより現場の負担軽減とキャリア多様化が期待されています。'
            },
            {
                keywords: ['キャリア', '目標設定', 'なりたい'],
                response: 'Kiyoさんのキャリア論では、「看護師になること」自体を目標にしてはいけないと警鐘を鳴らしています。それは免許取得がゴールになり、その後の燃え尽き症候群を招くからです。「看護師という資格を使って、どのような価値を社会に提供したいか」を定義することをお勧めしています。'
            },
            {
                keywords: ['投資', 'オルカン', '資産', 'お金'],
                response: '資産形成において、Kiyoさんはシンプルさを追求しています。余計な個別銘柄分析はせず、「全世界株式（オール・カントリー）」一本に絞り、夫婦で毎月10万円をただ淡々と自動積立するだけのシンプルな仕組みを実践しています。浮いた時間を自己投資や看護学習に充てるためです。'
            },
            {
                keywords: ['健康', '病気', 'utsu', '頑張りすぎる'],
                response: '頑張りすぎると病気になるという記事では、キャリア系YouTuberのUtsuさんの活動休止を例に挙げています。人間の身体は自然の一部であり、過度なストレスや社会的な役割のみに縛られると歪みが生じます。「自然に沿った適度な生き方」と、しなやかなセルフケアの重要性を発信しています。'
            },
            {
                keywords: ['本', 'のぞく', '無料', 'amazon', '読書'],
                response: 'Amazonの「サンプル」とGeminiなどの対話AIを組み合わせて、本の目次や要約から気になる本の中身を立体的に分析し、本当に購入すべきか事前に見極める賢い読書ハックを紹介しています。本選びの失敗をなくす素晴らしいライフハックです。'
            }
        ];

        const fab = document.getElementById('chatbot-fab');
        const chatWindow = document.getElementById('global-chat-window');
        const closeChat = document.getElementById('close-global-chat');
        const sendBtn = document.getElementById('send-chat');
        const chatInput = document.getElementById('chat-input');
        const messagesContainer = document.getElementById('chat-messages-container');

        fab.addEventListener('click', () => {
            chatWindow.classList.toggle('hidden');
            if (!chatWindow.classList.contains('hidden')) {
                setTimeout(() => {
                    chatWindow.style.opacity = '1';
                    chatWindow.style.transform = 'scale(1)';
                }, 50);
                chatInput.focus();
            }
        });

        closeChat.addEventListener('click', () => {
            chatWindow.style.opacity = '0';
            chatWindow.style.transform = 'scale(0.9)';
            setTimeout(() => chatWindow.classList.add('hidden'), 300);
        });

        sendBtn.addEventListener('click', sendChatMessage);
        chatInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') sendChatMessage();
        });

        function sendChatMessage() {
            const text = chatInput.value.trim();
            if (!text) return;

            appendBubble('user', text);
            chatInput.value = '';

            // Typing indicator
            const typingId = appendBubble('gemini', '...');

            setTimeout(() => {
                const typingBubble = document.getElementById(typingId);
                if (typingBubble) typingBubble.remove();

                const query = text.toLowerCase();
                let match = chatbotResponses.find(item => 
                    item.keywords.some(k => query.includes(k))
                );

                const responseText = match 
                    ? match.response 
                    : 'ご質問ありがとうございます！Kiyoさんのブログ情報（看護DXの急性期看護基準の緩和、TOEIC905点の学習本質論、インデックス全世界積立投資、Utsuさんの自然派ライフケア等）について質問を絞っていただくと、より詳細に解説できます。';

                appendBubble('gemini', responseText);
            }, 1000);
        }

        function appendBubble(sender, text) {
            const bubble = document.createElement('div');
            const id = 'bubble-' + Math.random().toString(36).substr(2, 9);
            bubble.id = id;
            if (sender === 'user') {
                bubble.className = 'bg-[#276183] text-white p-3 rounded-2xl max-w-[85%] self-end leading-relaxed shadow-sm';
            } else {
                bubble.className = 'bg-zinc-100 text-zinc-800 p-3 rounded-2xl max-w-[85%] self-start leading-relaxed shadow-sm';
            }
            bubble.textContent = text;
            messagesContainer.appendChild(bubble);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
            return id;
        }

        /* -------------------------------------------------------------
         * Text-to-Speech Player Controls
         * ------------------------------------------------------------- */
        const globalPlayer = document.getElementById('global-speech-player');
        const playerTitle = document.getElementById('speech-title');
        const playToggle = document.getElementById('audio-play-toggle');
        const playerWave = document.getElementById('player-wave');
        const closePlayer = document.getElementById('close-audio-player');
        let isPlaying = false;

        document.querySelectorAll('.speech-listen-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const article = e.currentTarget.closest('article');
                const title = article.querySelector('h2, h3').textContent;
                
                playerTitle.textContent = title;
                globalPlayer.classList.remove('hidden');
                
                // Play animation
                isPlaying = true;
                playToggle.innerHTML = '<span class="material-symbols-outlined text-sm">pause</span>';
                playerWave.querySelectorAll('.bar').forEach(b => b.style.animationPlayState = 'running');
            });
        });

        playToggle.addEventListener('click', () => {
            if (isPlaying) {
                playToggle.innerHTML = '<span class="material-symbols-outlined text-sm">play_arrow</span>';
                playerWave.querySelectorAll('.bar').forEach(b => b.style.animationPlayState = 'paused');
                isPlaying = false;
            } else {
                playToggle.innerHTML = '<span class="material-symbols-outlined text-sm">pause</span>';
                playerWave.querySelectorAll('.bar').forEach(b => b.style.animationPlayState = 'running');
                isPlaying = true;
            }
        });

        closePlayer.addEventListener('click', () => {
            globalPlayer.classList.add('hidden');
            isPlaying = false;
        });

        /* -------------------------------------------------------------
         * Database and Authentication Lock/Unlock Portal
         * ------------------------------------------------------------- */
        const authBtn = document.getElementById('auth-main-btn');
        const headerAuth = document.getElementById('header-auth-container');
        const vipLocker = document.getElementById('vip-locker');
        let isLoggedIn = false;

        authBtn.addEventListener('click', () => {
            authBtn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">sync</span> Loading...';
            setTimeout(() => {
                isLoggedIn = true;
                headerAuth.innerHTML = `
                    <div class="flex items-center gap-2 bg-white/80 border border-black/5 px-3 py-1.5 rounded-full shadow-sm animate-fade-in">
                        <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></span>
                        <span class="text-xs font-bold text-zinc-700">Kiyo Member</span>
                        <div class="w-6 h-6 rounded-full bg-primary text-white flex items-center justify-center font-bold text-[10px]">K</div>
                    </div>
                `;
                
                // Remove Locker overlay
                vipLocker.classList.add('unlocked');
                setTimeout(() => vipLocker.remove(), 500);
            }, 1200);
        });
    </script>
</body>
