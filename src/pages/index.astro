---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const categories = ['diary', 'english', 'study', 'reading', 'nursing', 'lifehack'] as const;
type Cat = (typeof categories)[number];

const catLabel: Record<Cat, string> = {
	diary: 'Diary',
	english: 'English',
	study: 'Study',
	reading: 'Reading',
	nursing: 'Nursing',
	lifehack: 'Lifehack',
};

// 全カテゴリの記事を集約し、公開日の新しい順に並べる
const posts = (
	await Promise.all(
		categories.map(async (cat) =>
			(await getCollection(cat)).map((post) => ({ cat, post })),
		),
	)
)
	.flat()
	.sort((a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf());

const fmtDate = (d: Date) =>
	d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---
<!DOCTYPE html>
<html lang="ja">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body class="bg-surface text-on-background font-body-md min-h-screen">
<Header />
<main class="w-full pt-28 md:pt-32 pb-20 px-5 max-w-[720px] mx-auto">
	<!-- Intro -->
	<section class="mb-12 md:mb-16">
		<h1 class="text-2xl md:text-[32px] font-bold text-text-primary leading-snug mb-4">こんにちは。</h1>
		<p class="text-text-secondary leading-loose mb-4">
			看護師として働きながら、英語の勉強やお金のこと、その日に考えたことを書きとめています。誰かのちょっとしたヒントになればうれしいです。
		</p>
		<a href="/about/#ai-writing" class="text-sm text-text-secondary underline underline-offset-4 hover:text-text-primary transition-colors">
			この記事は生成AIで書いています →
		</a>
	</section>

	<!-- Article list -->
	<div class="border-t border-border-subtle">
		{posts.map(({ cat, post }) => (
			<a href={`/${cat}/${post.id}/`} class="group block py-9 border-b border-border-subtle">
				{post.data.heroImage && (
					<div class="mb-5 overflow-hidden rounded">
						<Image src={post.data.heroImage} alt={post.data.title} class="w-full aspect-[16/9] object-cover" />
					</div>
				)}
				<div class="flex items-center gap-2.5 text-xs text-text-secondary mb-2.5">
					<span class="uppercase tracking-widest">{catLabel[cat]}</span>
					<span class="text-border-subtle">/</span>
					<time>{fmtDate(post.data.pubDate)}</time>
				</div>
				<h2 class="text-xl md:text-2xl font-bold text-text-primary leading-snug mb-2 group-hover:underline underline-offset-4 decoration-1">
					{post.data.title}
				</h2>
				<p class="text-text-secondary leading-relaxed line-clamp-2">
					{post.data.description}
				</p>
			</a>
		))}
	</div>
</main>
<Footer />
</body></html>
