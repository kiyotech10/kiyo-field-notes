    <!-- Floating Audio Speech Player Interface -->
    <div id="global-speech-player" class="floating-audio-panel fixed bottom-6 left-6 right-6 md:left-auto md:right-8 md:w-[360px] bg-white/95 backdrop-blur-md rounded-2xl p-4 border border-zinc-200 shadow-2xl flex items-center justify-between gap-4 z-50 hidden">
        <div class="flex items-center gap-3 overflow-hidden flex-1">
