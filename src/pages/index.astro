---
import { getCollection } from 'astro:content';
import ArticleThumb from '../components/ArticleThumb.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = [
	...(await getCollection('diary')).map((p) => ({ ...p, category: 'diary' as const })),
	...(await getCollection('english')).map((p) => ({ ...p, category: 'english' as const })),
	...(await getCollection('study')).map((p) => ({ ...p, category: 'study' as const })),
	...(await getCollection('reading')).map((p) => ({ ...p, category: 'reading' as const })),
	...(await getCollection('nursing')).map((p) => ({ ...p, category: 'nursing' as const })),
	...(await getCollection('lifehack')).map((p) => ({ ...p, category: 'lifehack' as const })),
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = allPosts.filter((p) => p.data.featured).slice(0, 4);
const recentPosts = allPosts.slice(0, 10);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<div class="intro">
				<h1 class="intro-title">{SITE_TITLE}</h1>
				<p class="intro-desc">{SITE_DESCRIPTION}</p>
				<p class="intro-profile">
					男性看護師 / TOEIC 905 / ライフハック好き。
					現場で気づいたことを、そのままメモしています。
					<a href="/about">→ About</a>
				</p>
				<div class="ai-notice">
					このブログの記事は <strong>AI（Claude）による執筆がメイン</strong> です。<br />
					アイデア・体験・視点は本人のものですが、文章はAIが生成しています。
				</div>
			</div>

			{featuredPosts.length > 0 && (
				<section class="section">
					<h2 class="section-label">Featured</h2>
					<div class="featured-grid">
						{featuredPosts.map((post) => (
							<a href={`/${post.category}/${post.id}/`} class="featured-card">
								<div class="card-thumb">
									<ArticleThumb title={post.data.title} category={post.category} size="large" />
								</div>
								<div class="card-body">
									<span class="card-cat">{post.category}</span>
									<h3 class="card-title">{post.data.title}</h3>
									<time class="card-date"><FormattedDate date={post.data.pubDate} /></time>
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			<section class="section">
				<h2 class="section-label">Recent</h2>
				<div class="filter-bar">
					<button class="filter-btn active" data-filter="all">All</button>
					<button class="filter-btn" data-filter="diary">Diary</button>
					<button class="filter-btn" data-filter="english">English</button>
					<button class="filter-btn" data-filter="study">Study</button>
					<button class="filter-btn" data-filter="reading">Reading</button>
					<button class="filter-btn" data-filter="nursing">Nursing</button>
					<button class="filter-btn" data-filter="lifehack">Lifehack</button>
				</div>
				<ul class="post-list">
					{recentPosts.map((post) => (
						<li class="fade-in" data-category={post.category}>
							<a href={`/${post.category}/${post.id}/`} class="post-row">
								<div class="post-thumb">
									<ArticleThumb title={post.data.title} category={post.category} />
								</div>
								<div class="post-info">
									<span class="post-cat">{post.category}</span>
									<span class="post-title">{post.data.title}</span>
									<time class="post-date"><FormattedDate date={post.data.pubDate} /></time>
								</div>
							</a>
						</li>
					))}
				</ul>
			</section>

			<script>
				const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
				const items = document.querySelectorAll<HTMLElement>('.post-list li[data-category]');
				btns.forEach((btn) => {
					btn.addEventListener('click', () => {
						btns.forEach((b) => b.classList.remove('active'));
						btn.classList.add('active');
						const f = btn.dataset.filter;
						items.forEach((item) => {
							const show = f === 'all' || item.dataset.category === f;
							item.style.display = show ? '' : 'none';
						});
					});
				});
			</script>

		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: 4em;
		padding-bottom: 2.5em;
		border-bottom: 1px solid var(--border);
	}
	.intro-title {
		font-size: 1.1em;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 0 0 0.5em;
		color: var(--text);
	}
	.intro-desc {
		font-size: 0.9em;
		color: var(--text-muted);
		margin: 0 0 0.6em;
		line-height: 1.7;
	}
	.intro-profile {
		font-size: 0.82em;
		color: var(--text-muted);
		margin: 0 0 1em;
		line-height: 1.7;
	}
	.ai-notice {
		font-size: 0.82em;
		line-height: 1.7;
		padding: 0.8em 1.1em;
		border-left: 3px solid var(--accent);
		background: #f0f6fa;
		color: var(--text);
	}

	.section {
		margin-bottom: 4em;
	}
	.section-label {
		font-size: 0.68em;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
		font-weight: 400;
		margin: 0 0 1.6em;
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.8em;
	}

	/* Featured grid */
	.featured-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}
	.featured-card {
		display: flex;
		flex-direction: column;
		gap: 0.9em;
		text-decoration: none;
		color: var(--text);
	}
	.featured-card:hover .card-thumb {
		opacity: 0.85;
	}
	.featured-card:hover .card-title {
		color: var(--accent);
	}
	.card-thumb {
		transition: opacity 0.2s;
	}
	.card-body {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
	}
	.card-cat {
		font-size: 0.62em;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 500;
	}
	.card-title {
		font-size: 0.95em;
		font-weight: 500;
		line-height: 1.5;
		margin: 0;
		letter-spacing: -0.01em;
		transition: color 0.15s;
	}
	.card-date {
		font-size: 0.72em;
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}

	/* Filter bar */
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 1.4em;
	}
	.filter-btn {
		font-size: 0.65em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.4em 0.9em;
		border: 1px solid var(--border);
		border-radius: 2em;
		background: transparent;
		color: var(--text-muted);
		cursor: pointer;
		transition: background 0.15s, color 0.15s, border-color 0.15s;
		font-family: var(--font-heading);
	}
	.filter-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.filter-btn.active {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}

	/* Recent list */
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		border-bottom: 1px solid var(--border);
	}
	.post-list li:first-child {
		border-top: 1px solid var(--border);
	}
	.post-row {
		display: grid;
		grid-template-columns: 130px 1fr;
		gap: 1.2em;
		padding: 1.1em 0;
		text-decoration: none;
		color: var(--text);
		align-items: center;
	}
	.post-row:hover .post-title {
		color: var(--accent);
	}
	.post-row:hover .post-thumb {
		opacity: 0.85;
	}
	.post-thumb {
		transition: opacity 0.2s;
	}
	.post-info {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}
	.post-cat {
		font-size: 0.6em;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 500;
	}
	.post-title {
		font-size: 0.9em;
		font-weight: 500;
		line-height: 1.5;
		letter-spacing: -0.01em;
		transition: color 0.15s;
	}
	.post-date {
		font-size: 0.7em;
		color: var(--text-muted);
		letter-spacing: 0.02em;
	}

	@media (max-width: 600px) {
		.featured-grid {
			grid-template-columns: 1fr;
		}
		.post-row {
			grid-template-columns: 100px 1fr;
			gap: 0.9em;
		}
	}
</style>
