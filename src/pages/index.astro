    <style>
        body {
            background-color: #F8FAFB;
            color: #1A1C1E;
            -webkit-font-smoothing: antialiased;
            font-family: 'Inter', 'Noto Sans JP', sans-serif;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .antigravity-float {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
        }
        .antigravity-float:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0px 20px 50px rgba(0, 0, 0, 0.08);
        }
        .well-input {
            background: rgba(0, 0, 0, 0.02);
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }
        .well-input:focus {
            background: #ffffff;
            border-color: #276183;
            outline: none;
            box-shadow: 0 0 0 4px rgba(39, 97, 131, 0.1);
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
        /* Audio visualizer animations */
        .waveform-bars {
            display: flex;
            align-items: center;
            gap: 2px;
            height: 16px;
        }
        .bar {
            width: 2px;
            height: 4px;
            background: #276183;
            border-radius: 9999px;
            animation: bounce-bar 0.8s infinite alternate ease-in-out;
        }
        .bar:nth-child(2) { animation-delay: 0.15s; }
        .bar:nth-child(3) { animation-delay: 0.3s; }
        .bar:nth-child(4) { animation-delay: 0.45s; }
        .bar:nth-child(5) { animation-delay: 0.6s; }
        @keyframes bounce-bar {
            0% { height: 4px; }
            100% { height: 16px; }
        }

        /* Float elements standard transition */
        .floating-audio-panel {
            animation: slide-up-panel 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
        }
        @keyframes slide-up-panel {
            0% { transform: translateY(30px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }

        /* Bubble animations */
        #chat-messages-container div {
            animation: pop-bubble 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
            transform-origin: left bottom;
        }
        @keyframes pop-bubble {
            0% { transform: scale(0.85); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        /* VIP Locker card logic styling */
        .vip-lock-overlay {
            transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .vip-lock-overlay.unlocked {
            opacity: 0;
            pointer-events: none;
            transform: translateY(-20px);
        }
    </style>
