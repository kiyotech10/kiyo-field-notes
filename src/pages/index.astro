---
import { getCollection } from 'astro:content';
import ArticleThumb from '../components/ArticleThumb.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = [
	...(await getCollection('diary')).map((p) => ({ ...p, category: 'diary' as const })),
	...(await getCollection('english')).map((p) => ({ ...p, category: 'english' as const })),
	...(await getCollection('study')).map((p) => ({ ...p, category: 'study' as const })),
	...(await getCollection('reading')).map((p) => ({ ...p, category: 'reading' as const })),
	...(await getCollection('nursing')).map((p) => ({ ...p, category: 'nursing' as const })),
	...(await getCollection('lifehack')).map((p) => ({ ...p, category: 'lifehack' as const })),
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = allPosts.filter((p) => p.data.featured).slice(0, 4);
const featuredIds = new Set(featuredPosts.map((p) => `${p.category}:${p.id}`));
const recentPosts = allPosts.slice(0, 20);

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<!-- Profile & Intro Section (Simple & Minimal) -->
			<div class="profile-card">
				<div class="profile-content">
					<h1 class="profile-title">はじめまして、Kiyoです。</h1>
					<p class="profile-desc">
						医療分野で働く男性看護師です。日々の仕事や学びのプロセスで得た「より良く生きるための知恵」や「学習の効率化」について発信しています。
					</p>
					<div class="intro-badges">
						<span class="ai-badge">AIによる執筆</span>
					</div>
				</div>
				
				<!-- JSCP風の優しい波形（ウェーブ）SVGをカード底部に配置 -->
				<div class="profile-wave">
					<svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
						<path d="M0,64L80,69.3C160,75,320,85,480,80C640,75,800,53,960,48C1120,43,1280,53,1360,58.7L1440,64L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z" fill="var(--bg-wave-1)" opacity="0.3"/>
						<path d="M0,32L80,42.7C160,53,320,75,480,80C640,85,800,75,960,64C1120,53,1280,43,1360,37.3L1440,32L1440,120L1360,120C1280,120,1120,120,960,120C800,120,640,120,480,120C320,120,160,120,80,120L0,120Z" fill="var(--bg-wave-2)" opacity="0.6"/>
					</svg>
				</div>
			</div>

			<!-- Search -->
			<div class="search-wrap">
				<div class="search-box">
					<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
					<input
						id="search-input"
						type="search"
						placeholder="記事を検索…"
						autocomplete="off"
						spellcheck="false"
					/>
					<button id="search-clear" class="clear-btn" aria-label="クリア">×</button>
				</div>
				<div id="search-results" class="search-results" hidden></div>
			</div>


			<!-- Recent -->
			<section class="section" id="recent-section">
				<h2 class="section-label">Recent</h2>
				<!-- Filter bar -->
				<div class="filter-bar">
					<button class="filter-btn active" data-filter="all">All</button>
					<button class="filter-btn" data-filter="diary">Diary</button>
					<button class="filter-btn" data-filter="english">English</button>
					<button class="filter-btn" data-filter="study">Study</button>
					<button class="filter-btn" data-filter="reading">Reading</button>
					<button class="filter-btn" data-filter="nursing">Nursing</button>
					<button class="filter-btn" data-filter="lifehack">Lifehack</button>
				</div>
				<ul class="post-list">
					{recentPosts.map((post) => (
						<li class="fade-in post-item" data-category={post.category}>
							<div class="post-row">
								<div class="post-info">
									<span class="post-cat">{post.category}</span>
									<a href={`/${post.category}/${post.id}/`} class="post-title-link">{post.data.title}</a>
									<div class="post-meta">
										<time class="post-date"><FormattedDate date={post.data.pubDate} /></time>
										{(post.data.tags ?? []).slice(0, 3).map((tag) => (
											<a href={`/tags/${tag}/`} class="tag-chip">#{tag}</a>
										))}
									</div>
								</div>
							</div>
						</li>
					))}
				</ul>
			</section>

			<!-- Tags cloud -->
			{allTags.length > 0 && (
				<section class="section tags-section">
					<h2 class="section-label">Tags</h2>
					<div class="tags-cloud">
						{allTags.map((tag) => (
							<a href={`/tags/${tag}/`} class="tag-pill">#{tag}</a>
						))}
					</div>
				</section>
			)}

		</main>
		<Footer />
	</body>
</html>

<script>
	// Category filter
	const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const items = document.querySelectorAll<HTMLElement>('.post-list li[data-category]');
	btns.forEach((btn) => {
		btn.addEventListener('click', () => {
			btns.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');
			const f = btn.dataset.filter;
			items.forEach((item) => {
				item.style.display = f === 'all' || item.dataset.category === f ? '' : 'none';
			});
		});
	});

	// Search
	type Post = {
		title: string;
		description: string;
		category: string;
		tags: string[];
		pubDate: string;
		url: string;
	};

	const input = document.getElementById('search-input') as HTMLInputElement;
	const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
	const resultsEl = document.getElementById('search-results') as HTMLDivElement;
	const featuredSection = document.getElementById('featured-section');
	const recentSection = document.getElementById('recent-section');

	let posts: Post[] = [];
	let loaded = false;

	async function loadPosts() {
		if (loaded) return;
		loaded = true;
		try {
			const res = await fetch('/search.json');
			posts = await res.json();
		} catch {
			posts = [];
		}
	}

	function highlight(text: string, query: string): string {
		if (!query) return text;
		const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
		return text.replace(new RegExp(escaped, 'gi'), (m) => `<mark>${m}</mark>`);
	}

	function renderResults(query: string) {
		const q = query.trim().toLowerCase();
		if (!q) {
			resultsEl.hidden = true;
			if (featuredSection) featuredSection.style.display = '';
			recentSection!.style.display = '';
			clearBtn.style.display = 'none';
			return;
		}

		clearBtn.style.display = '';
		if (featuredSection) featuredSection.style.display = 'none';
		recentSection!.style.display = 'none';

		const matched = posts.filter((p) => {
			const haystack = `${p.title} ${p.description} ${p.category} ${p.tags.join(' ')}`.toLowerCase();
			return haystack.includes(q);
		});

		if (matched.length === 0) {
			resultsEl.innerHTML = '<p class="no-results">記事が見つかりませんでした。</p>';
		} else {
			resultsEl.innerHTML = `
				<p class="results-count">${matched.length}件</p>
				<ul class="results-list">
					${matched.map((p) => `
						<li>
							<a href="${p.url}" class="result-row">
								<span class="result-cat">${p.category}</span>
								<span class="result-title">${highlight(p.title, query.trim())}</span>
								<div class="result-meta">
									<span class="result-date">${p.pubDate.slice(0, 10)}</span>
									${p.tags.map((t) => `<a href="/tags/${t}/" class="tag-chip">#${t}</a>`).join('')}
								</div>
							</a>
						</li>
					`).join('')}
				</ul>
			`;
		}
		resultsEl.hidden = false;
	}

	input.addEventListener('focus', loadPosts);
	input.addEventListener('input', (e) => {
		loadPosts().then(() => renderResults((e.target as HTMLInputElement).value));
	});
	clearBtn.addEventListener('click', () => {
		input.value = '';
		renderResults('');
		input.focus();
	});

	// Intersection Observer for fade-in
	const observer = new IntersectionObserver(
		(entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
		{ threshold: 0.05 }
	);
	document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>

<style>
	/* Profile Card (Simple & Minimal) */
	.profile-card {
		--bg-wave-1: #d5e6e3;
		--bg-wave-2: #faf8f5; /* Seamlessly matches the warm sand white blog background */
		position: relative;
		overflow: hidden;
		padding: 3.2em 3em 5.5em; /* Expanded padding for a luxurious feel */
		border-radius: 32px;
		background: linear-gradient(135deg, #eef6f5 0%, #e6f0f3 100%);
		border: 1px solid rgba(210, 230, 227, 0.4);
		box-shadow: 0 10px 35px rgba(30, 58, 52, 0.015);
		max-width: 820px; /* Limits width beautifully on ultrawide screens */
		margin: 0 auto 4.5em; /* Centered with generous bottom spacing */
	}
	.profile-content {
		position: relative;
		z-index: 5;
		max-width: 680px; /* Limits the reading width beautifully */
		display: flex;
		flex-direction: column;
		gap: 1em;
	}
	.profile-title {
		font-size: 1.6em;
		font-family: var(--font-heading);
		color: #1a3530;
		font-weight: 700;
		margin: 0;
		letter-spacing: -0.01em;
	}
	.profile-desc {
		font-size: 0.95em;
		line-height: 1.8;
		color: #435853;
		margin: 0;
	}
	.intro-badges {
		margin-top: 0.4em;
		display: flex;
		justify-content: flex-start;
	}
	.ai-badge {
		font-size: 0.72em;
		font-weight: 600;
		color: #4a635d;
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid rgba(26, 53, 48, 0.08);
		padding: 0.3em 1em;
		border-radius: 999px;
		letter-spacing: 0.05em;
		transition: var(--transition-google);
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.01);
	}
	.ai-badge:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(26, 53, 48, 0.06);
		background: #ffffff;
		border-color: rgba(26, 53, 48, 0.15);
	}
	
	.profile-wave {
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 100%;
		height: 80px;
		z-index: 1;
		pointer-events: none;
	}
	.profile-wave svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	@media (max-width: 600px) {
		.profile-card {
			padding: 2.2em 1.8em 4.2em;
			border-radius: 24px;
		}
		.profile-wave {
			height: 55px;
		}
	}

	/* Search */
	.search-wrap {
		max-width: 600px; /* Slim search bar centered elegantly */
		margin: 0 auto 5em; /* Deep breathing space below */
		position: relative;
	}
	.search-box {
		display: flex;
		align-items: center;
		gap: 0.8em;
		border: 1px solid #dadce0;
		border-radius: 28px; /* Google Pill Search Bar */
		padding: 0.65em 1.2em;
		background: #ffffff;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
		transition: var(--transition-google);
	}
	.search-box:focus-within {
		border-color: rgba(0, 0, 0, 0.02);
		background: #ffffff;
		box-shadow: 0 4px 20px rgba(32, 33, 36, 0.08);
	}
	.search-icon {
		color: var(--text-muted);
		flex-shrink: 0;
	}
	#search-input {
		border: none;
		background: transparent;
		outline: none;
		font-size: 0.9em;
		font-family: var(--font-body);
		color: var(--text);
		width: 100%;
	}
	#search-input::placeholder { color: var(--text-muted); }
	.clear-btn {
		display: none;
		border: none;
		background: none;
		color: var(--text-muted);
		cursor: pointer;
		font-size: 1.1em;
		padding: 0;
		line-height: 1;
		flex-shrink: 0;
	}
	.clear-btn:hover { color: var(--text); }

	.search-results {
		margin-top: 0.8em;
		border: 1px solid var(--border);
		border-radius: 20px; /* Highly rounded dropdown */
		background: #ffffff;
		overflow: hidden;
		box-shadow: 0 8px 28px rgba(32, 33, 36, 0.08);
	}
	.no-results {
		font-size: 0.85em;
		color: var(--text-muted);
		padding: 1.2em 1.5em;
		margin: 0;
	}
	.results-count {
		font-size: 0.72em;
		color: var(--text-muted);
		letter-spacing: 0.06em;
		padding: 1em 1.5em 0.2em;
		margin: 0;
		font-weight: 600;
		text-transform: uppercase;
	}
	.results-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.results-list li { border-bottom: 1px solid var(--border); }
	.results-list li:last-child { border-bottom: none; }
	.result-row {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		padding: 1em 1.5em;
		text-decoration: none;
		color: var(--text);
		transition: var(--transition-google);
	}
	.result-row:hover { background: #f8f9fa; text-decoration: none; }
	.result-cat {
		font-size: 0.62em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 700;
	}
	.result-title {
		font-size: 0.95em;
		font-weight: 600;
		line-height: 1.45;
	}
	.result-title :global(mark) {
		background: #e8f0fe;
		color: #1967d2;
		border-radius: 4px;
		padding: 0.1em 0.25em;
	}
	.result-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 0.2rem;
	}
	.result-date {
		font-size: 0.72em;
		color: var(--text-muted);
	}

	/* Section */
	.section { margin-bottom: 5.5em; } /* Expanded margin for minimalist aesthetic */
	.section-label {
		font-size: 0.72em;
		letter-spacing: 0.15em; /* Increased tracking for high-end editorial feel */
		text-transform: uppercase;
		color: var(--text-muted);
		font-weight: 600;
		margin: 0 0 2em; /* Generous bottom spacing */
		border-bottom: 1px solid var(--border);
		padding-bottom: 1em; /* Generous padding */
	}

	/* Featured grid */
	.featured-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
	}
	.featured-card {
		display: flex;
		flex-direction: column;
		gap: 0.9em;
		text-decoration: none;
		color: var(--text);
		background: #ffffff;
		padding: 1.2rem;
		border-radius: 24px;
		border: 1px solid rgba(0, 0, 0, 0.03);
		transition: var(--transition-google);
		box-shadow: 0 4px 16px rgba(0,0,0,0.01);
	}
	.featured-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 28px rgba(0,0,0,0.04);
		border-color: rgba(26, 115, 232, 0.12);
	}
	.featured-card:hover .card-title { color: var(--accent); }
	.card-thumb {
		border-radius: 16px;
		overflow: hidden;
		transition: var(--transition-google);
	}
	.card-body {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		padding: 0.2rem;
	}
	.card-cat {
		font-size: 0.65em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 700;
	}
	.card-title {
		font-size: 1.05em;
		font-weight: 700;
		line-height: 1.45;
		margin: 0;
		letter-spacing: -0.01em;
		transition: var(--transition-google);
	}
	.card-footer {
		display: flex;
		align-items: center;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 0.3rem;
	}
	.card-date {
		font-size: 0.72em;
		color: var(--text-muted);
	}

	/* Filter bar */
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6em;
		margin-bottom: 1.8em; /* Restored original margin */
	}
	.filter-btn {
		font-size: 0.72em;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.5em 1.3em;
		border: 1px solid #dadce0;
		border-radius: 999px; /* Google Pill Filter Chip */
		background: #ffffff;
		color: var(--text-muted);
		cursor: pointer;
		transition: var(--transition-google);
		font-family: var(--font-heading);
	}
	.filter-btn:hover {
		background: #f1f3f4;
		border-color: #bdc1c6;
		color: var(--text);
	}
	.filter-btn.active {
		background: #202124;
		border-color: #202124;
		color: #ffffff;
		box-shadow: 0 2px 8px rgba(0,0,0,0.12);
	}

	/* Post list */
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.post-item {
		position: relative; /* Criteria point for absolute stretched link */
		border-bottom: 1px solid var(--border);
		transition: var(--transition-google);
	}
	.post-item:first-child { border-top: 1px solid var(--border); }
	
	.post-row {
		display: block;
		padding: 1.8em 1.5em; /* Expanded padding for clean list space */
		margin: 0 -1.5em;
		border-radius: 24px; /* Slightly softer corners */
		transition: var(--transition-google);
	}
	.post-row:hover {
		background: #ffffff;
		box-shadow: 0 4px 20px rgba(0,0,0,0.03);
	}
	.post-row:hover .post-title-link {
		color: var(--accent);
	}
	
	.post-info {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}
	.post-cat {
		font-size: 0.62em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 700;
	}
	.post-title-link {
		font-size: 1.05em; /* Slightly larger title for premium typography presence */
		font-weight: 600;
		line-height: 1.45;
		letter-spacing: -0.01em;
		color: var(--text);
		text-decoration: none;
		transition: var(--transition-google);
	}
	/* Stretched link to make the entire row clickable safely without nesting <a> tags */
	.post-title-link::after {
		content: "";
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		left: 0;
		z-index: 1;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		flex-wrap: wrap;
		margin-top: 0.25em;
	}
	.post-date {
		font-size: 0.72em;
		color: var(--text-muted);
		white-space: nowrap;
		position: relative;
		z-index: 2; /* Put date above the stretched link */
	}

	/* Tag chips (shared) */
	.tag-chip {
		font-size: 0.65em;
		color: var(--text-muted);
		text-decoration: none;
		border: 1px solid #dadce0;
		border-radius: 999px;
		padding: 0.2em 0.7em;
		background: #ffffff;
		transition: var(--transition-google);
		white-space: nowrap;
		position: relative;
		z-index: 2; /* Put tags above the stretched link to ensure they are separately clickable */
	}
	.tag-chip:hover {
		color: var(--accent);
		border-color: var(--accent-light);
		background: rgba(26, 115, 232, 0.04);
		text-decoration: none;
	}

	/* Tags cloud */
	.tags-section { margin-bottom: 3em; }
	.tags-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6em;
	}
	.tag-pill {
		font-size: 0.75em;
		font-weight: 500;
		color: var(--text-muted);
		text-decoration: none;
		border: 1px solid #dadce0;
		border-radius: 999px;
		padding: 0.4em 1em;
		background: #ffffff;
		transition: var(--transition-google);
	}
	.tag-pill:hover {
		color: var(--accent);
		border-color: var(--accent-light);
		background: rgba(26, 115, 232, 0.04);
		text-decoration: none;
	}

	@media (max-width: 600px) {
		.featured-grid {
			grid-template-columns: 1fr;
			gap: 1.2rem;
		}
		.post-row {
			padding: 1.2em 0.6em;
			margin: 0 -0.6em;
		}
	}
</style>
