<script>
  import Chart from 'chart.js/auto';

  // ----------------------------------------------------------------
  // カテゴリ定義
  // ----------------------------------------------------------------
  const CATEGORIES = [
    { id: 'food',         label: '食費',      color: '#f97316',
      keywords: ['スーパー','イオン','ライフ','西友','マルエツ','ヨーカドー','業務スーパー','コストコ','食品','弁当','惣菜','タイラヤ','TAIRAYA','レストラン','ファミレス','ガスト','デニーズ','ジョナサン','サイゼリヤ','すき家','吉野家','松屋','なか卯','ケンタッキー','マクドナルド','モスバーガー','バーガー','ピザ','寿司','焼肉','ラーメン','丸亀製麺','うどん','そば','定食','居酒屋','かつ','とんかつ','矢田','和國','HANAGATAYA','はなが','NewDays','ニューデイズ','エキュート','菓子','茶','和菓子'] },
    { id: 'convenience',  label: 'コンビニ',  color: '#eab308',
      keywords: ['セブン-イレブン','セブンイレブン','7-eleven','ファミリーマート','ファミマ','ローソン','ミニストップ','デイリーヤマザキ','ポプラ','コンビニ'] },
    { id: 'cafe',         label: 'カフェ',    color: '#a16207',
      keywords: ['スターバックス','スタバ','ドトール','コメダ','タリーズ','ベローチェ','エクセルシオール','サンマルク','カフェ','café','coffee','珈琲','CHIENOWA'] },
    { id: 'transport',    label: '交通費',    color: '#0ea5e9',
      keywords: ['suica','pasmo','パスモ','モバイルpasmo','電車','バス','タクシー','地下鉄','JR','jr','東急','小田急','京急','西武鉄道','西武','東武','メトロ','ガソリン','eneos','出光','コスモ','駐車場','駐輪場','タイムズ','times','カーシェア','タイムズカー'] },
    { id: 'medical',      label: '医療・健康', color: '#6366f1',
      keywords: ['病院','クリニック','薬局','ドラッグ','マツキヨ','マツモトキヨシ','ウエルシア','ツルハ','コクミン','サンドラッグ','スギ薬局','調剤','整骨','歯科','眼科','内科','スポーツデポ','スポーツ'] },
    { id: 'telecom',      label: '通信・サービス', color: '#14b8a6',
      keywords: ['楽天モバイル','docomo','ドコモ','au','softbank','ソフトバンク','マイクロソフト','microsoft','bb.excite','excite','google','apple','アップル','ntt','line','spotify','netflix','amazon prime','amazonプライム','プライム会費','claude','anthropic'] },
    { id: 'entertainment',label: '娯楽',      color: '#ec4899',
      keywords: ['映画','シネマ','ゲーム','カラオケ','温泉','銭湯','ジム','ゴルフ','ボウリング','ディズニー','ユニバ','遊園地','水族館','動物園','美術館','博物館'] },
    { id: 'shopping',     label: 'ショッピング',color: '#8b5cf6',
      keywords: ['ユニクロ','gu','しまむら','zara','h&m','無印','ムジ','ニトリ','ヤマダ','ビックカメラ','ヨドバシ','ドン・キホーテ','ドンキ','amazon','楽天','メルカリ','メルポーチ','百貨店','デパート','アウトレット','ダイソー','daiso','セリア','キャンドゥ','ビバホーム','ホームセンター','コーナン'] },
    { id: 'other',        label: 'その他',    color: '#94a3b8', keywords: [] },
    // 特別なシステムカテゴリ（自動分類・集計制御用）
    { id: 'charge',       label: 'チャージ',  color: '#0ea5e9', keywords: [] },
    { id: 'income',       label: '受け取り',  color: '#10b981', keywords: [] },
    { id: 'send',         label: '送金',      color: '#ef4444', keywords: [] },
  ];

  const CATEGORY_MAP: Record<string, (typeof CATEGORIES)[0]> = {};
  for (const cat of CATEGORIES) CATEGORY_MAP[cat.id] = cat;

  // ----------------------------------------------------------------
  // 型定義
  // ----------------------------------------------------------------
  interface Transaction {
    id: string;
    date: Date;
    store: string;
    amount: number;
    category: string;
    source: string;
  }

  interface ImportedFile {
    name: string;
    count: number;
    importedAt: string;
  }

  // ----------------------------------------------------------------
  // アプリ状態
  // ----------------------------------------------------------------
  let transactions: Transaction[] = [];
  let importedFiles: ImportedFile[] = [];
  let budgets: Record<string, number> = {};
  let selectedMonth = formatMonth(new Date());

  let categoryChart: Chart | null = null;
  let monthlyChart: Chart | null = null;

  // ----------------------------------------------------------------
  // LocalStorage
  // ----------------------------------------------------------------
  const LS_TX    = 'paypay_transactions';
  const LS_BUD   = 'paypay_budgets';
  const LS_FILES = 'paypay_files';

  function saveData() {
    localStorage.setItem(LS_TX,    JSON.stringify(transactions.map(t => ({ ...t, date: t.date.toISOString() }))));
    localStorage.setItem(LS_BUD,   JSON.stringify(budgets));
    localStorage.setItem(LS_FILES, JSON.stringify(importedFiles));
  }

  function loadData() {
    const txRaw = localStorage.getItem(LS_TX);
    if (txRaw) {
      try {
        const parsed = JSON.parse(txRaw) as Array<Transaction & { date: string }>;
        // nullガードを追加し、Invalid Date (不正な日付) を持つレコードを除外
        transactions = (parsed || [])
          .filter(t => t && t.date)
          .map(t => ({ ...t, date: new Date(t.date), source: t.source ?? '' }))
          .filter(t => t.date && !isNaN(t.date.getTime()));
      } catch (e) {
        console.error('Failed to parse transactions:', e);
        transactions = [];
      }
    } else {
      transactions = [];
    }

    const budRaw = localStorage.getItem(LS_BUD);
    if (budRaw) {
      try {
        budgets = JSON.parse(budRaw) || {};
      } catch {
        budgets = {};
      }
    } else {
      budgets = {};
    }

    const filesRaw = localStorage.getItem(LS_FILES);
    if (filesRaw) {
      try {
        importedFiles = JSON.parse(filesRaw) || [];
      } catch {
        importedFiles = [];
      }
    } else {
      importedFiles = [];
    }
  }

  // ----------------------------------------------------------------
  // CSV パーサー (UTF-8/Shift-JIS 対応)
  // ----------------------------------------------------------------
  function parseCSVRow(line: string): string[] {
    const result: string[] = [];
    let cur = '';
    let inQ = false;
    for (let i = 0; i < line.length; i++) {
      const c = line[i];
      if (c === '"') {
        if (inQ && line[i + 1] === '"') { cur += '"'; i++; }
        else inQ = !inQ;
      } else if (c === ',' && !inQ) {
        result.push(cur.trim()); cur = '';
      } else {
        cur += c;
      }
    }
    result.push(cur.trim());
    return result;
  }

  function findColIndex(headers: string[], candidates: string[]): number {
    for (const c of candidates) {
      for (let i = 0; i < headers.length; i++) {
        const normalized = headers[i].replace(/[（）()　\s]/g, '').toLowerCase();
        if (normalized.includes(c.toLowerCase())) return i;
      }
    }
    return -1;
  }

  function parseAmount(s: string): number {
    if (!s) return 0;
    const cleaned = s.replace(/[,，¥￥\s"]/g, '');
    const n = parseFloat(cleaned);
    return isNaN(n) ? 0 : n;
  }

  function parseDate(s: string): Date | null {
    const cleaned = s.replace(/[""]/g, '').trim();
    const m = cleaned.match(/(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})/);
    if (!m) return null;
    return new Date(parseInt(m[1]), parseInt(m[2]) - 1, parseInt(m[3]));
  }

  function parseCSV(text: string, filename = ''): Transaction[] {
    const lines = text.trim().split(/\r?\n/).filter(l => l.trim());
    if (lines.length < 2) return [];

    // 有効なヘッダー行（日付列がある行）を自動探索（先頭10行まで）
    let headerIdx = -1;
    let headers: string[] = [];
    let dateCol = -1;

    for (let i = 0; i < Math.min(10, lines.length); i++) {
      const cols = parseCSVRow(lines[i]).map(h => h.replace(/[""]/g, '').trim());
      const tempDateCol = findColIndex(cols, ['利用日', '取引日', '日付', '年月日']);
      if (tempDateCol >= 0) {
        headerIdx = i;
        headers = cols;
        dateCol = tempDateCol;
        break;
      }
    }

    if (headerIdx < 0 || dateCol < 0) {
      alert('CSVの解析に失敗しました。ヘッダー（列名）が認識できません。');
      return [];
    }

    const storeCol   = findColIndex(headers, ['利用先', '取引先', '店舗', '相手先', '摘要', '相手', '取引先']);
    const expenseCol = findColIndex(headers, ['出金金額', '利用金額', '支払金額', '出金', '金額']);
    const chargeCol  = findColIndex(headers, ['入金金額', 'チャージ金額', '入金', 'チャージ', '受取']);
    const typeCol    = findColIndex(headers, ['取引内容', '取引区分', '取引種別', 'タイプ', '内容']);

    const result: Transaction[] = [];

    // ヘッダー行の次の行からパースを開始
    for (let i = headerIdx + 1; i < lines.length; i++) {
      const cols = parseCSVRow(lines[i]);
      const dateStr   = cols[dateCol]    ?? '';
      const store     = (storeCol >= 0   ? cols[storeCol]   ?? '' : '').replace(/[""]/g, '').trim();
      const expenseStr= expenseCol >= 0  ? cols[expenseCol] ?? '' : '';
      const chargeStr = chargeCol >= 0   ? cols[chargeCol]  ?? '' : '';
      const typeStr   = (typeCol >= 0    ? cols[typeCol]    ?? '' : '').replace(/[""]/g, '').trim();

      const date = parseDate(dateStr);
      if (!date) continue;

      const expAmt = parseAmount(expenseStr);
      const chrAmt = parseAmount(chargeStr);

      let amount = 0;
      let category = 'other';
      const typeNorm = typeStr.toLowerCase();

      // 取引内容（内容）に基づいた金額とカテゴリの選定
      if (typeNorm.includes('チャージ') || typeNorm.includes('入金')) {
        amount = chrAmt || expAmt;
        category = 'charge';
      } else if (typeNorm.includes('受け取') || typeNorm.includes('受取') || typeNorm.includes('受領') || typeNorm.includes('受け取り')) {
        amount = chrAmt || expAmt;
        category = 'income';
      } else if (typeNorm.includes('送った') || typeNorm.includes('送金') || typeNorm.includes('送る')) {
        amount = expAmt || chrAmt;
        category = 'send';
      } else {
        // 通常の支払い（出金金額 > 0 または入金金額 == 0 の場合）
        amount = expAmt || chrAmt;
        category = detectCategory(store);
      }

      if (amount > 0) {
        result.push({
          id: `csv_${date.getTime()}_${i}_${Math.random()}`,
          date,
          store: store || typeStr || '不明な取引',
          amount,
          category,
          source: filename,
        });
      }
    }

    return result.sort((a, b) => b.date.getTime() - a.date.getTime());
  }

  function detectCategory(store: string): string {
    const norm = store.normalize('NFKC').toLowerCase();
    for (const cat of CATEGORIES) {
      if (cat.id === 'other') continue;
      for (const kw of cat.keywords) {
        if (norm.includes(kw.normalize('NFKC').toLowerCase())) return cat.id;
      }
    }
    return 'other';
  }

  // ----------------------------------------------------------------
  // ユーティリティ
  // ----------------------------------------------------------------
  function formatMonth(d: Date): string {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  }

  function formatYen(n: number): string {
    return '¥' + Math.round(n).toLocaleString('ja-JP');
  }

  function formatDateJP(d: Date): string {
    return `${d.getMonth() + 1}/${d.getDate()}`;
  }

  function txInMonth(tx: Transaction, ym: string): boolean {
    return formatMonth(tx.date) === ym;
  }

  // ----------------------------------------------------------------
  // データ集計 ＆ インサイト
  // ----------------------------------------------------------------
  function monthlyTotal(ym: string): number {
    // チャージ (charge) と 受け取り (income) は純粋な支出から除外する
    return transactions
      .filter(t => txInMonth(t, ym) && t.category !== 'charge' && t.category !== 'income')
      .reduce((s, t) => s + t.amount, 0);
  }

  function categoryTotals(ym: string): Record<string, number> {
    const totals: Record<string, number> = {};
    for (const cat of CATEGORIES) totals[cat.id] = 0;
    for (const t of transactions) {
      // チャージ (charge) と 受け取り (income) は円グラフなどのカテゴリ内訳から除外
      if (txInMonth(t, ym) && t.category !== 'charge' && t.category !== 'income') {
        totals[t.category] = (totals[t.category] ?? 0) + t.amount;
      }
    }
    return totals;
  }

  function last6Months(): string[] {
    const months: string[] = [];
    const d = new Date(selectedMonth + '-01');
    for (let i = 5; i >= 0; i--) {
      const m = new Date(d.getFullYear(), d.getMonth() - i, 1);
      months.push(formatMonth(m));
    }
    return months;
  }

  // 今月よく使う店舗 TOP 3を抽出
  function renderInsights() {
    const container = document.getElementById('top-stores-list') as HTMLElement;
    if (!container) return;

    // チャージ (charge) と 受け取り (income) は店舗ランキング分析から除外
    const currentTxs = transactions.filter(t => txInMonth(t, selectedMonth) && t.category !== 'charge' && t.category !== 'income');
    if (currentTxs.length === 0) {
      container.innerHTML = '<p class="no-insight-text">分析するデータがありません</p>';
      return;
    }

    // 店舗ごとの支払額を集計
    const storeAgg: Record<string, number> = {};
    for (const t of currentTxs) {
      const storeName = t.store || '手動追加または不明';
      storeAgg[storeName] = (storeAgg[storeName] ?? 0) + t.amount;
    }

    const sortedStores = Object.entries(storeAgg)
      .map(([name, val]) => ({ name, value: val }))
      .sort((a, b) => b.value - a.value)
      .slice(0, 3);

    container.innerHTML = '';
    sortedStores.forEach((item, index) => {
      const rank = index + 1;
      const li = document.createElement('div');
      li.className = 'insight-item';
      li.innerHTML = `
        <div class="insight-rank-store">
          <span class="insight-rank rank-${rank}">${rank}</span>
          <span class="insight-store-name" title="${item.name}">${item.name}</span>
        </div>
        <span class="insight-amt">${formatYen(item.value)}</span>
      `;
      container.appendChild(li);
    });
  }

  // ----------------------------------------------------------------
  // グラフ描画 (Chart.js)
  // ----------------------------------------------------------------
  function renderCategoryChart() {
    const totals = categoryTotals(selectedMonth);
    const cats = CATEGORIES.filter(c => totals[c.id] > 0);
    if (cats.length === 0) { destroyChart('chart-category'); return; }

    const canvas = document.getElementById('chart-category') as HTMLCanvasElement;
    if (categoryChart) categoryChart.destroy();
    categoryChart = new Chart(canvas, {
      type: 'doughnut',
      data: {
        labels: cats.map(c => c.label),
        datasets: [{
          data: cats.map(c => totals[c.id]),
          backgroundColor: cats.map(c => c.color),
          borderWidth: 2,
          borderColor: '#fff',
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'right', labels: { font: { size: 11 }, boxWidth: 12, padding: 10 } },
          tooltip: {
            callbacks: {
              label: ctx => ` ${formatYen(ctx.parsed)} (${Math.round(ctx.parsed / cats.reduce((s,c)=>s+totals[c.id],0)*100)}%)`,
            },
          },
        },
      },
    });
  }

  function renderMonthlyChart() {
    const months = last6Months();
    const canvas = document.getElementById('chart-monthly') as HTMLCanvasElement;
    if (monthlyChart) monthlyChart.destroy();
    monthlyChart = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: months.map(m => { const [y, mo] = m.split('-'); return `${mo}月`; }),
        datasets: [{
          label: '支出',
          data: months.map(m => monthlyTotal(m)),
          backgroundColor: months.map(m => m === selectedMonth ? '#e60012' : '#fbcfe8'),
          borderRadius: 8,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: { label: ctx => ' ' + formatYen(ctx.parsed.y) },
          },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: v => '¥' + Number(v).toLocaleString('ja-JP'), font: { size: 10 } },
            grid: { color: '#f1f3f4' },
          },
          x: { grid: { display: false }, ticks: { font: { size: 11 } } },
        },
      },
    });
  }

  function destroyChart(id: string) {
    const canvas = document.getElementById(id) as HTMLCanvasElement;
    if (canvas) { 
      const ctx = canvas.getContext('2d'); 
      if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height); 
    }
  }

  // ----------------------------------------------------------------
  // UI レンダリング
  // ----------------------------------------------------------------
  function renderStats() {
    // チャージ (charge) と 受け取り (income) は純粋な支出から除外する
    const txs = transactions.filter(t => txInMonth(t, selectedMonth) && t.category !== 'charge' && t.category !== 'income');
    const total = txs.reduce((s, t) => s + t.amount, 0);
    const count = txs.length;
    const avg = count > 0 ? total / count : 0;

    // 予算合計（システム用カテゴリを除いて集計）
    const totalBudget = Object.entries(budgets)
      .filter(([catId]) => catId !== 'charge' && catId !== 'income' && catId !== 'send')
      .reduce((s, [_, v]) => s + v, 0);

    (document.getElementById('stat-total') as HTMLElement).textContent = formatYen(total);
    (document.getElementById('stat-count') as HTMLElement).textContent = count + '件';
    (document.getElementById('stat-avg') as HTMLElement).textContent = count > 0 ? formatYen(avg) : '-';
    (document.getElementById('stat-budget') as HTMLElement).textContent = totalBudget > 0 ? formatYen(totalBudget) : '未設定';

    const [y, m] = selectedMonth.split('-');
    (document.getElementById('month-label') as HTMLElement).textContent = `${y}年${parseInt(m)}月`;
  }

  function renderBudget() {
    const totals = categoryTotals(selectedMonth);
    const container = document.getElementById('budget-list') as HTMLElement;
    if (!container) return;
    container.innerHTML = '';

    for (const cat of CATEGORIES) {
      // システム用およびその他のカテゴリは予算設定の対象外
      if (cat.id === 'other' || cat.id === 'charge' || cat.id === 'income' || cat.id === 'send') continue;
      const spent = totals[cat.id] ?? 0;
      const budget = budgets[cat.id] ?? 0;
      const pct = budget > 0 ? Math.min(100, (spent / budget) * 100) : 0;
      const isOver = budget > 0 && spent > budget;
      const barColor = isOver ? '#dc2626' : spent / (budget || 1) > 0.8 ? '#d97706' : cat.color;

      const div = document.createElement('div');
      div.className = 'budget-item';
      div.innerHTML = `
        <div class="budget-item-header">
          <span class="budget-cat-name">
            <span class="cat-dot" style="background:${cat.color}"></span>
            ${cat.label}
          </span>
          <span class="budget-status ${isOver ? 'budget-over' : ''}">${formatYen(spent)}${budget > 0 ? ' / ' + formatYen(budget) : ''}</span>
        </div>
        <div class="budget-input-row">
          <input class="budget-input" type="number" min="0" step="1000" placeholder="予算なし"
                 value="${budget > 0 ? budget : ''}" data-cat="${cat.id}" />
          <span style="font-size:0.75rem;color:var(--text-muted);white-space:nowrap">円/月</span>
        </div>
        ${budget > 0 ? `
          <div class="budget-progress">
            <div class="budget-bar" style="width:${pct}%;background:${barColor}"></div>
          </div>
        ` : ''}
      `;
      container.appendChild(div);
    }

    container.querySelectorAll('.budget-input').forEach(inp => {
      inp.addEventListener('change', () => {
        const el = inp as HTMLInputElement;
        const cat = el.dataset.cat!;
        const val = parseFloat(el.value);
        if (!isNaN(val) && val > 0) budgets[cat] = val;
        else delete budgets[cat];
        saveData();
        renderBudget();
        renderStats();
      });
    });
  }

  function renderTransactions(filterText = '', filterCat = '', sortBy = 'date-desc') {
    const tbody = document.getElementById('transactions-body') as HTMLElement;
    const noResults = document.getElementById('no-results') as HTMLElement;
    const table = document.getElementById('transactions-table') as HTMLElement;
    if (!tbody) return;

    let txs = transactions.filter(t => {
      if (!txInMonth(t, selectedMonth)) return false;
      if (filterText && !t.store.toLowerCase().includes(filterText.toLowerCase())) return false;
      if (filterCat && t.category !== filterCat) return false;
      return true;
    });

    // 並び替え処理
    txs = txs.sort((a, b) => {
      if (sortBy === 'date-desc') return b.date.getTime() - a.date.getTime();
      if (sortBy === 'date-asc') return a.date.getTime() - b.date.getTime();
      if (sortBy === 'amount-desc') return b.amount - a.amount;
      if (sortBy === 'amount-asc') return a.amount - b.amount;
      return 0;
    });

    if (txs.length === 0) {
      table.hidden = true;
      noResults.hidden = false;
    } else {
      table.hidden = false;
      noResults.hidden = true;
    }

    tbody.innerHTML = '';
    for (const tx of txs) {
      const cat = CATEGORY_MAP[tx.category] ?? CATEGORY_MAP['other'];
      const tr = document.createElement('tr');
      
      // 金額表示のカスタマイズ（チャージ、受け取り、送金を視覚的にわかりやすく色分け）
      let amountHTML = '';
      if (tx.category === 'income') {
        amountHTML = `<td class="td-amount" style="color:#10b981;font-weight:bold">+${formatYen(tx.amount)}</td>`;
      } else if (tx.category === 'charge') {
        amountHTML = `<td class="td-amount" style="color:#0ea5e9;font-weight:normal">${formatYen(tx.amount)} <span style="font-size:0.72rem;color:var(--text-muted);font-weight:normal">(チャージ)</span></td>`;
      } else if (tx.category === 'send') {
        amountHTML = `<td class="td-amount" style="color:#ef4444;font-weight:bold">${formatYen(tx.amount)} <span style="font-size:0.72rem;color:#ef4444;font-weight:normal">(送金)</span></td>`;
      } else {
        amountHTML = `<td class="td-amount">${formatYen(tx.amount)}</td>`;
      }

      tr.innerHTML = `
        <td class="td-date">${formatDateJP(tx.date)}</td>
        <td class="td-store" title="${tx.store}">${tx.store || '手動入力'}</td>
        ${amountHTML}
        <td class="td-cat">
          <select data-id="${tx.id}">
            ${CATEGORIES.map(c => `<option value="${c.id}" ${c.id === tx.category ? 'selected' : ''}>${c.label}</option>`).join('')}
          </select>
        </td>
        <td class="th-del">
          <button class="btn-del" data-id="${tx.id}" title="削除">×</button>
        </td>
      `;
      tbody.appendChild(tr);
    }

    // カテゴリ変更イベント
    tbody.querySelectorAll('select').forEach(sel => {
      sel.addEventListener('change', () => {
        const el = sel as HTMLSelectElement;
        const id = el.dataset.id!;
        const tx = transactions.find(t => t.id === id);
        if (tx) {
          tx.category = el.value;
          saveData();
          renderCategoryChart();
          renderBudget();
          renderInsights();
        }
      });
    });

    // 個別取引削除イベント
    tbody.querySelectorAll('.btn-del').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!;
        if (confirm('この取引レコードを削除しますか？')) {
          transactions = transactions.filter(t => t.id !== id);
          saveData();
          renderAll();
          if (transactions.length === 0) hideApp();
        }
      });
    });
  }

  function renderCategoryFilter() {
    const sel = document.getElementById('category-filter') as HTMLSelectElement;
    if (!sel) return;
    const usedCats = new Set(transactions.filter(t => txInMonth(t, selectedMonth)).map(t => t.category));
    sel.innerHTML = '<option value="">すべてのカテゴリ</option>';
    for (const cat of CATEGORIES) {
      if (usedCats.has(cat.id)) {
        const opt = document.createElement('option');
        opt.value = cat.id;
        opt.textContent = cat.label;
        sel.appendChild(opt);
      }
    }
  }

  function deleteFile(filename: string) {
    if (!confirm(`「${filename}」の決済データを一括削除しますか？`)) return;
    transactions = transactions.filter(t => t.source !== filename);
    importedFiles = importedFiles.filter(f => f.name !== filename);
    if (transactions.length > 0) {
      selectedMonth = formatMonth(transactions[0].date);
    }
    saveData();
    if (transactions.length === 0) { hideApp(); return; }
    renderAll();
  }

  function renderFiles() {
    const container = document.getElementById('files-list') as HTMLElement;
    if (!container) return;
    container.innerHTML = '';
    if (importedFiles.length === 0) return;

    for (const f of importedFiles) {
      const d = new Date(f.importedAt);
      const dateStr = `${d.getMonth()+1}/${d.getDate()} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
      const chip = document.createElement('div');
      chip.className = 'file-chip';
      chip.innerHTML = `
        <span class="file-chip-name" title="${f.name}">${f.name}</span>
        <span class="file-chip-meta">${f.count}件 · ${dateStr}</span>
        <button class="file-chip-del" data-name="${f.name}" title="削除">×</button>
      `;
      container.appendChild(chip);
    }

    container.querySelectorAll('.file-chip-del').forEach(btn => {
      btn.addEventListener('click', () => deleteFile((btn as HTMLElement).dataset.name!));
    });
  }

  function renderAll() {
    renderStats();
    renderCategoryChart();
    renderMonthlyChart();
    renderBudget();
    renderInsights();
    renderCategoryFilter();
    renderFiles();
    renderTransactions(
      (document.getElementById('search-input') as HTMLInputElement).value,
      (document.getElementById('category-filter') as HTMLSelectElement).value,
      (document.getElementById('sort-filter') as HTMLSelectElement).value,
    );
  }

  function showApp() {
    (document.getElementById('empty-state') as HTMLElement).hidden = true;
    (document.getElementById('app') as HTMLElement).hidden = false;
    (document.getElementById('reset-btn') as HTMLElement).style.display = '';
  }

  function hideApp() {
    (document.getElementById('empty-state') as HTMLElement).hidden = false;
    (document.getElementById('app') as HTMLElement).hidden = true;
    (document.getElementById('reset-btn') as HTMLElement).style.display = 'none';
  }

  // ----------------------------------------------------------------
  // データバックアップ ＆ 復元 (JSON)
  // ----------------------------------------------------------------
  function exportData() {
    const data = {
      transactions: transactions.map(t => ({ ...t, date: t.date.toISOString() })),
      budgets,
      importedFiles,
      exportedAt: new Date().toISOString()
    };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `paypay-家計管理-バックアップ-${formatMonth(new Date())}.json`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  function importData(file: File) {
    const reader = new FileReader();
    reader.readAsText(file);
    reader.onload = (e) => {
      try {
        const data = JSON.parse(e.target?.result as string);
        if (!data.transactions) {
          alert('不正なバックアップファイルです。');
          return;
        }

        // マージ処理
        const parsedTxs = (data.transactions as any[]).map(t => ({
          ...t,
          date: new Date(t.date)
        })) as Transaction[];

        const existingIds = new Set(transactions.map(t => t.id));
        const newTxs = parsedTxs.filter(t => !existingIds.has(t.id));
        transactions = [...transactions, ...newTxs].sort((a, b) => b.date.getTime() - a.date.getTime());

        // 予算と履歴を上書きマージ
        budgets = { ...budgets, ...data.budgets };
        
        const existingFileNames = new Set(importedFiles.map(f => f.name));
        const newFiles = (data.importedFiles || []).filter((f: any) => !existingFileNames.has(f.name)) as ImportedFile[];
        importedFiles = [...importedFiles, ...newFiles];

        if (transactions.length > 0) selectedMonth = formatMonth(transactions[0].date);

        saveData();
        showApp();
        renderAll();
        alert('データを正常に復元・統合しました！');
      } catch {
        alert('ファイルの読み込みに失敗しました。');
      }
    };
  }

  // ----------------------------------------------------------------
  // 手動追加モーダルの制御
  // ----------------------------------------------------------------
  function openAddModal() {
    const modal = document.getElementById('add-modal') as HTMLElement;
    const dateInput = document.getElementById('add-date') as HTMLInputElement;
    // ローカルタイムゾーンに基づいた YYYY-MM-DD 形式の日付をセット
    dateInput.value = new Date().toLocaleDateString('sv-SE');
    modal.hidden = false;
  }

  function closeAddModal() {
    const modal = document.getElementById('add-modal') as HTMLElement;
    modal.hidden = true;
    (document.getElementById('add-form') as HTMLFormElement).reset();
  }

  function handleManualAdd(e: Event) {
    e.preventDefault();
    const dateVal = (document.getElementById('add-date') as HTMLInputElement).value;
    const storeVal = (document.getElementById('add-store') as HTMLInputElement).value.trim();
    const amountVal = parseFloat((document.getElementById('add-amount') as HTMLInputElement).value);
    const catVal = (document.getElementById('add-category') as HTMLSelectElement).value;

    // バリデーションチェックと分かりやすい日本語での警告
    if (!dateVal) {
      alert('日付を入力してください。');
      return;
    }

    const parsedDate = new Date(dateVal);
    if (isNaN(parsedDate.getTime())) {
      alert('有効な日付を入力してください。');
      return;
    }

    if (!storeVal) {
      alert('店舗名 / 内容を入力してください。');
      return;
    }

    if (isNaN(amountVal) || amountVal <= 0) {
      alert('金額には1以上の数値を入力してください。');
      return;
    }

    const newTx: Transaction = {
      id: `manual_${parsedDate.getTime()}_${Math.random()}`,
      date: parsedDate,
      store: storeVal,
      amount: amountVal,
      category: catVal,
      source: '手動入力'
    };

    transactions.unshift(newTx);
    transactions.sort((a, b) => b.date.getTime() - a.date.getTime());

    // 手動ファイルのメタを登録
    if (!importedFiles.some(f => f.name === '手動入力')) {
      importedFiles.push({ name: '手動入力', count: 1, importedAt: new Date().toISOString() });
    } else {
      const f = importedFiles.find(f => f.name === '手動入力')!;
      f.count = transactions.filter(t => t.source === '手動入力').length;
      f.importedAt = new Date().toISOString();
    }

    selectedMonth = formatMonth(newTx.date);
    saveData();
    showApp();
    renderAll();
    closeAddModal();
  }

  // ----------------------------------------------------------------
  // CSV 読み込み
  // ----------------------------------------------------------------
  function onCSVLoad(file: File) {
    const reader = new FileReader();
    reader.readAsArrayBuffer(file);
    reader.onload = (e) => {
      const buf = e.target?.result as ArrayBuffer;
      let text = '';
      try {
        text = new TextDecoder('utf-8').decode(buf);
        // 日本語の典型的な列名キーワードが含まれていない、または文字化け文字「」が含まれる場合は Shift-JIS と判定
        const hasKeyword = ['利用', '取引', '日付', '金額', '出金', '入金'].some(k => text.includes(k));
        if (text.includes('') || !hasKeyword) {
          text = new TextDecoder('shift-jis').decode(buf);
        }
      } catch {
        text = new TextDecoder('shift-jis').decode(buf);
      }

      const parsed = parseCSV(text, file.name);
      if (parsed.length === 0) {
        alert('有効な取引データをCSVから検出できませんでした。');
        return;
      }

      const existingIds = new Set(transactions.map(t => t.id));
      const newTxs = parsed.filter(t => !existingIds.has(t.id));
      transactions = [...transactions, ...newTxs].sort((a, b) => b.date.getTime() - a.date.getTime());

      importedFiles = importedFiles.filter(f => f.name !== file.name);
      importedFiles.unshift({ name: file.name, count: parsed.length, importedAt: new Date().toISOString() });

      if (transactions.length > 0) selectedMonth = formatMonth(transactions[0].date);

      saveData();
      showApp();
      renderAll();
    };
  }

  // ----------------------------------------------------------------
  // DOMContentLoaded
  // ----------------------------------------------------------------
  document.addEventListener('DOMContentLoaded', () => {
    loadData();

    if (transactions.length > 0) {
      // 念のため、有効な日付を持つ最初のトランザクションから選択月を特定
      const validTx = transactions.find(t => t.date && !isNaN(t.date.getTime()));
      if (validTx) {
        selectedMonth = formatMonth(validTx.date);
        showApp();
        renderAll();
      } else {
        selectedMonth = formatMonth(new Date());
        hideApp();
      }
    }

    // CSV読み込み
    const csvInput = document.getElementById('csv-input') as HTMLInputElement;
    csvInput.addEventListener('change', () => {
      const file = csvInput.files?.[0];
      if (file) { onCSVLoad(file); csvInput.value = ''; }
    });

    // バックアップ＆復元
    document.getElementById('export-btn')!.addEventListener('click', exportData);
    const restoreInput = document.getElementById('restore-input') as HTMLInputElement;
    restoreInput.addEventListener('change', () => {
      const file = restoreInput.files?.[0];
      if (file) { importData(file); restoreInput.value = ''; }
    });

    // モーダル制御
    document.getElementById('manual-add-btn')!.addEventListener('click', openAddModal);
    document.getElementById('empty-manual-btn')!.addEventListener('click', openAddModal);
    document.getElementById('modal-close')!.addEventListener('click', closeAddModal);
    document.getElementById('modal-cancel')!.addEventListener('click', closeAddModal);
    document.getElementById('modal-overlay')!.addEventListener('click', closeAddModal);
    document.getElementById('add-form')!.addEventListener('submit', handleManualAdd);

    // リセット
    document.getElementById('reset-btn')!.addEventListener('click', () => {
      if (!confirm('本当にすべてのデータをリセットしますか？')) return;
      transactions = [];
      budgets = {};
      importedFiles = [];
      localStorage.removeItem(LS_TX);
      localStorage.removeItem(LS_BUD);
      localStorage.removeItem(LS_FILES);
      if (categoryChart) { categoryChart.destroy(); categoryChart = null; }
      if (monthlyChart)  { monthlyChart.destroy();  monthlyChart = null; }
      hideApp();
    });

    // 月ナビゲーション
    document.getElementById('prev-month')!.addEventListener('click', () => {
      const [y, m] = selectedMonth.split('-').map(Number);
      const prev = new Date(y, m - 2, 1);
      selectedMonth = formatMonth(prev);
      renderAll();
    });
    document.getElementById('next-month')!.addEventListener('click', () => {
      const [y, m] = selectedMonth.split('-').map(Number);
      const next = new Date(y, m, 1);
      selectedMonth = formatMonth(next);
      renderAll();
    });

    // 検索・フィルター・ソート
    const searchInp = document.getElementById('search-input') as HTMLInputElement;
    const catFilt = document.getElementById('category-filter') as HTMLSelectElement;
    const sortFilt = document.getElementById('sort-filter') as HTMLSelectElement;

    searchInp.addEventListener('input', () => {
      renderTransactions(searchInp.value, catFilt.value, sortFilt.value);
    });
    catFilt.addEventListener('change', () => {
      renderTransactions(searchInp.value, catFilt.value, sortFilt.value);
    });
    sortFilt.addEventListener('change', () => {
      renderTransactions(searchInp.value, catFilt.value, sortFilt.value);
    });
  });
</script>
