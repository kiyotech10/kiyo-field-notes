---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('reading')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = 'Reading';
const description = '読んだ本・論文・記事のメモ。';

const fmtDate = (d: Date) =>
	d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---
<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
	</head>
	<body class="bg-surface text-on-background font-body-md min-h-screen">
		<Header />
		<main class="w-full pt-28 md:pt-32 pb-20 px-5 max-w-[720px] mx-auto">
			<div class="mb-10">
				<a href="/" class="text-xs text-text-secondary uppercase tracking-widest hover:text-text-primary transition-colors">&larr; Home</a>
				<h1 class="text-2xl md:text-[32px] font-bold text-text-primary mt-3 mb-2">{title}</h1>
				<p class="text-text-secondary">{description}</p>
			</div>

			{posts.length === 0 ? (
				<p class="text-text-secondary py-10 border-t border-border-subtle">まだ記事がありません。</p>
			) : (
				<div class="border-t border-border-subtle">
					{posts.map((post) => (
						<a href={`/reading/${post.id}/`} class="group block py-9 border-b border-border-subtle">
							{post.data.heroImage && (
								<div class="mb-5 overflow-hidden rounded">
									<Image src={post.data.heroImage} alt={post.data.title} class="w-full aspect-[16/9] object-cover" />
								</div>
							)}
							<time class="block text-xs text-text-secondary mb-2.5">{fmtDate(post.data.pubDate)}</time>
							<h2 class="text-xl md:text-2xl font-bold text-text-primary leading-snug mb-2 group-hover:underline underline-offset-4 decoration-1">{post.data.title}</h2>
							<p class="text-text-secondary leading-relaxed line-clamp-2">{post.data.description}</p>
						</a>
					))}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
