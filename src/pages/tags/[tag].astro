---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const categories = ['diary', 'english', 'study', 'reading', 'nursing', 'lifehack'] as const;
	const allPosts = (
		await Promise.all(
			categories.map(async (cat) => {
				const items = await getCollection(cat);
				return items.map((p) => ({ ...p, category: cat }));
			})
		)
	).flat();

	const tagMap = new Map<string, typeof allPosts>();
	for (const post of allPosts) {
		for (const tag of post.data.tags ?? []) {
			if (!tagMap.has(tag)) tagMap.set(tag, []);
			tagMap.get(tag)!.push(post);
		}
	}

	return [...tagMap.entries()].map(([tag, posts]) => ({
		params: { tag },
		props: { tag, posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) },
	}));
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`#${tag} — ${SITE_TITLE}`} description={`タグ「${tag}」の記事一覧`} />
	</head>
	<body class="bg-surface text-on-background font-body-md min-h-screen">
		<Header />
		<main class="w-full pt-28 md:pt-32 pb-20 px-5 max-w-[720px] mx-auto">
			<div class="mb-10">
				<a href="/" class="text-xs text-text-secondary uppercase tracking-widest hover:text-text-primary transition-colors">&larr; Home</a>
				<h1 class="text-2xl md:text-[32px] font-bold text-text-primary mt-3 mb-2">#{tag}</h1>
				<p class="text-text-secondary">{posts.length}件の記事</p>
			</div>

			<div class="border-t border-border-subtle">
				{posts.map((post) => (
					<a href={`/${post.category}/${post.id}/`} class="group block py-9 border-b border-border-subtle">
						<div class="flex items-center gap-2.5 text-xs text-text-secondary mb-2.5">
							<span class="uppercase tracking-widest">{post.category}</span>
							<span class="text-border-subtle">/</span>
							<time><FormattedDate date={post.data.pubDate} /></time>
						</div>
						<h2 class="text-xl md:text-2xl font-bold text-text-primary leading-snug mb-2 group-hover:underline underline-offset-4 decoration-1">
							{post.data.title}
						</h2>
						<p class="text-text-secondary leading-relaxed line-clamp-2">
							{post.data.description}
						</p>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
